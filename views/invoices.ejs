<div class="page-header">
  <h1>Invoices</h1>
  <button class="btn btn-primary" onclick="openModal('genModal')">📄 Generate Invoice</button>
</div>

<div class="section-card">
  <% if (invoices.length > 0) { %>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Invoice #</th>
            <th>Type</th>
            <th>To</th>
            <th>Period</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% invoices.forEach(i => {
            const landlord = landlords.find(l => l.LandlordID === i.LandlordID) || {};
            const tenant = tenants.find(t => t.TenantID === i.TenantID) || {};
            const isMgmt = (i.Type || i.type) === 'Management Fee';
          %>
            <tr>
              <td><strong><%= i.InvoiceNo || i.invoiceNo %></strong></td>
              <td><span class="badge <%= isMgmt ? 'badge-warning' : 'badge-success' %>"><%= i.Type || i.type %></span></td>
              <td><%= isMgmt ? (landlord.FullName || 'N/A') : (tenant.FullName || 'N/A') %></td>
              <td><%= i.Period || i.period %></td>
              <td class="amount">$<%= parseFloat(i['Net Amount'] || i.netAmount || i['Fee Amount'] || i.feeAmount || 0).toFixed(2) %></td>
              <td><span class="badge <%= (i.Status || i.status) === 'Paid' ? 'badge-success' : 'badge-warning' %>"><%= i.Status || i.status %></span></td>
              <td class="actions">
                <a href="/invoice/<%= i.InvoiceID || i.invoiceId %>/pdf" target="_blank" class="btn-small">📄 PDF</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mobile-cards">
      <% invoices.forEach(i => {
        const landlord = landlords.find(l => l.LandlordID === i.LandlordID) || {};
        const tenant = tenants.find(t => t.TenantID === i.TenantID) || {};
        const isMgmt = (i.Type || i.type) === 'Management Fee';
      %>
        <div class="card">
          <div class="card-header">
            <h3><%= i.InvoiceNo || i.invoiceNo %></h3>
            <span class="badge <%= (i.Status || i.status) === 'Paid' ? 'badge-success' : 'badge-warning' %>"><%= i.Status || i.status %></span>
          </div>
          <p>📄 Type: <span class="badge <%= isMgmt ? 'badge-warning' : 'badge-success' %>"><%= i.Type || i.type %></span></p>
          <p>👤 To: <%= isMgmt ? (landlord.FullName || 'N/A') : (tenant.FullName || 'N/A') %></p>
          <p>📅 Period: <%= i.Period || i.period %></p>
          <p>💵 Amount: $<%= parseFloat(i['Net Amount'] || i.netAmount || i['Fee Amount'] || i.feeAmount || 0).toFixed(2) %></p>
          <div class="card-actions">
            <a href="/invoice/<%= i.InvoiceID || i.invoiceId %>/pdf" target="_blank" class="btn-small">📄 View PDF</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty">No invoices generated yet.</p>
  <% } %>
</div>

<div id="genModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('genModal')">&times;</span>
    <h2>Generate Invoice</h2>
    <form action="/invoices/generate" method="POST">
      <div class="form-group"><label>Invoice Type</label>
        <select name="type" id="invoiceType" onchange="toggleInvoiceFields()" required>
          <option value="">Select Type</option>
          <option value="Management Fee">Management Fee (to Landlord)</option>
          <option value="Rent Invoice">Rent Invoice (to Tenant)</option>
        </select>
      </div>

      <div id="landlordField" class="form-group" style="display:none;">
        <label>Landlord</label>
        <select name="landlordId">
          <option value="">Select Landlord</option>
          <% landlords.filter(l => l.Status === 'Active').forEach(l => { %>
            <option value="<%= l.LandlordID %>"><%= l.FullName %></option>
          <% }) %>
        </select>
      </div>

      <div id="tenantField" class="form-group" style="display:none;">
        <label>Tenant</label>
        <select name="tenantId">
          <option value="">Select Tenant</option>
          <% tenants.filter(t => t.Status === 'Active').forEach(t => { %>
            <option value="<%= t.TenantID %>"><%= t.FullName %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group"><label>Property (Optional - for Management Fee)</label>
        <select name="propertyId">
          <option value="">All Properties</option>
          <% properties.filter(p => p.Status === 'Active').forEach(p => { %>
            <option value="<%= p.PropertyID %>"><%= p.PropertyName %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group"><label>Period (YYYY-MM)</label><input type="text" name="period" value="<%= new Date().toISOString().slice(0, 7) %>" required pattern="\d{4}-\d{2}"></div>
      <button type="submit" class="btn btn-primary">Generate Invoice</button>
    </form>
  </div>
</div>

<script>
function toggleInvoiceFields() {
  const type = document.getElementById('invoiceType').value;
  document.getElementById('landlordField').style.display = type === 'Management Fee' ? 'block' : 'none';
  document.getElementById('tenantField').style.display = type === 'Rent Invoice' ? 'block' : 'none';
}
</script>