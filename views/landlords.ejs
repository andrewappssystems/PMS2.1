<div class="page-header">
  <h1>Landlords</h1>
  <button class="btn btn-primary" onclick="openModal('addModal')">➕ Add Landlord</button>
</div>

<div class="section-card">
  <% if (landlords.length > 0) { %>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Short Code</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% landlords.forEach(l => { %>
            <tr>
              <td><strong><%= l.FullName %></strong></td>
              <td><%= l.Email %></td>
              <td><%= l.Phone %></td>
              <td><%= l.ShortCode || '-' %></td>
              <td><span class="badge <%= l.Status === 'Active' ? 'badge-success' : 'badge-danger' %>"><%= l.Status %></span></td>
              <td class="actions">
                <button class="btn-small" onclick="editLandlord('<%= l.LandlordID %>', '<%= l.FullName %>', '<%= l.Email %>', '<%= l.Phone %>', '<%= l.ShortCode %>', '<%= l.Status %>')">✏️</button>
                <form action="/landlords/<%= l.LandlordID %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Delete this landlord?')">
                  <button type="submit" class="btn-small btn-danger">🗑️</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mobile-cards">
      <% landlords.forEach(l => { %>
        <div class="card">
          <div class="card-header">
            <h3><%= l.FullName %></h3>
            <span class="badge <%= l.Status === 'Active' ? 'badge-success' : 'badge-danger' %>"><%= l.Status %></span>
          </div>
          <p>📧 <%= l.Email %></p>
          <p>📱 <%= l.Phone %></p>
          <p>🏷️ <%= l.ShortCode || '-' %></p>
          <div class="card-actions">
            <button class="btn-small" onclick="editLandlord('<%= l.LandlordID %>', '<%= l.FullName %>', '<%= l.Email %>', '<%= l.Phone %>', '<%= l.ShortCode %>', '<%= l.Status %>')">✏️ Edit</button>
            <form action="/landlords/<%= l.LandlordID %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Delete?')">
              <button type="submit" class="btn-small btn-danger">🗑️</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty">No landlords found. Add your first landlord.</p>
  <% } %>
</div>

<div id="addModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('addModal')">&times;</span>
    <h2>Add Landlord</h2>
    <form action="/landlords" method="POST">
      <div class="form-group"><label>Full Name</label><input type="text" name="fullName" required></div>
      <div class="form-group"><label>Email</label><input type="email" name="email" required></div>
      <div class="form-group"><label>Phone</label><input type="tel" name="phone" required></div>
      <div class="form-group"><label>Short Code</label><input type="text" name="shortCode" placeholder="e.g. LL001"></div>
      <button type="submit" class="btn btn-primary">Save Landlord</button>
    </form>
  </div>
</div>

<div id="editModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('editModal')">&times;</span>
    <h2>Edit Landlord</h2>
    <form id="editForm" method="POST">
      <input type="hidden" name="_method" value="PUT">
      <div class="form-group"><label>Full Name</label><input type="text" name="fullName" id="editName" required></div>
      <div class="form-group"><label>Email</label><input type="email" name="email" id="editEmail" required></div>
      <div class="form-group"><label>Phone</label><input type="tel" name="phone" id="editPhone" required></div>
      <div class="form-group"><label>Short Code</label><input type="text" name="shortCode" id="editShortCode"></div>
      <div class="form-group"><label>Status</label>
        <select name="status" id="editStatus">
          <option value="Active">Active</option>
          <option value="Inactive">Inactive</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">Update Landlord</button>
    </form>
  </div>
</div>

<script>
function editLandlord(id, name, email, phone, shortCode, status) {
  document.getElementById('editForm').action = '/landlords/' + id;
  document.getElementById('editName').value = name;
  document.getElementById('editEmail').value = email;
  document.getElementById('editPhone').value = phone;
  document.getElementById('editShortCode').value = shortCode || '';
  document.getElementById('editStatus').value = status || 'Active';
  openModal('editModal');
}
</script>