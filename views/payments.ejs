<div class="page-header">
  <h1>Rent Payments</h1>
  <button class="btn btn-primary" onclick="openModal('paymentModal')">➕ Record Payment</button>
</div>

<div class="section-card">
  <% if (payments.length > 0) { %>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Tenant</th>
            <th>Unit</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Method</th>
            <th>Period</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% payments.forEach(p => {
            const tenant = tenants.find(t => t.TenantID === p.TenantID) || {};
            const unit = units.find(u => u.UnitID === p.UnitID) || {};
          %>
            <tr>
              <td><strong><%= tenant.FullName || p.TenantID %></strong></td>
              <td><%= unit.UnitNumber || p.UnitID %></td>
              <td class="amount">$<%= parseFloat(p.Amount).toFixed(2) %></td>
              <td><%= p.PaymentDate %></td>
              <td><%= p.PaymentMethod || 'Cash' %></td>
              <td><%= p.Period %></td>
              <td class="actions">
                <a href="/receipt/<%= p.PaymentID %>" target="_blank" class="btn-small">🧾 Receipt</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mobile-cards">
      <% payments.forEach(p => {
        const tenant = tenants.find(t => t.TenantID === p.TenantID) || {};
        const unit = units.find(u => u.UnitID === p.UnitID) || {};
      %>
        <div class="card">
          <div class="card-header">
            <h3><%= tenant.FullName || 'Unknown' %></h3>
            <span class="badge badge-success">$<%= parseFloat(p.Amount).toFixed(2) %></span>
          </div>
          <p>🏠 Unit: <%= unit.UnitNumber || p.UnitID %></p>
          <p>📅 <%= p.PaymentDate %> | <%= p.Period %></p>
          <p>💳 <%= p.PaymentMethod || 'Cash' %></p>
          <% if (p.Notes) { %><p>📝 <%= p.Notes %></p><% } %>
          <div class="card-actions">
            <a href="/receipt/<%= p.PaymentID %>" target="_blank" class="btn-small">🧾 Receipt</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty">No payments recorded.</p>
  <% } %>
</div>

<div id="paymentModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('paymentModal')">&times;</span>
    <h2>Record Payment</h2>
    <form action="/payments" method="POST">
      <div class="form-group">
        <label>Tenant</label>
        <select name="tenantId" required>
          <option value="">Select Tenant</option>
          <% tenants.filter(t => t.Status === 'Active').forEach(t => { 
            const unit = units.find(u => u.UnitID === t.UnitID) || {};
          %>
            <option value="<%= t.TenantID %>"><%= t.FullName %> - Unit <%= unit.UnitNumber || t.UnitID %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group"><label>Amount ($)</label><input type="number" name="amount" step="0.01" required></div>
      <div class="form-group"><label>Payment Date</label><input type="date" name="paymentDate" value="<%= new Date().toISOString().split('T')[0] %>" required></div>
      <div class="form-group">
        <label>Method</label>
        <select name="paymentMethod">
          <option value="Cash">Cash</option>
          <option value="Bank Transfer">Bank Transfer</option>
          <option value="Mobile Money">Mobile Money</option>
          <option value="Cheque">Cheque</option>
        </select>
      </div>
      <div class="form-group"><label>Period (e.g., 2024-01)</label><input type="text" name="period" value="<%= new Date().toISOString().slice(0, 7) %>" required></div>
      <div class="form-group"><label>Notes</label><textarea name="notes" placeholder="Optional notes..."></textarea></div>
      <button type="submit" class="btn btn-primary">Record Payment</button>
    </form>
  </div>
</div>