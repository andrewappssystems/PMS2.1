<div class="page-header">
  <h1>Units</h1>
  <button class="btn btn-primary" onclick="openModal('addModal')">➕ Add Unit</button>
</div>

<div class="section-card">
  <% if (units.length > 0) { %>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Unit #</th>
            <th>Property</th>
            <th>Type</th>
            <th>Rent</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% units.forEach(u => {
            const property = properties.find(p => p.PropertyID === u.PropertyID) || {};
          %>
            <tr>
              <td><strong><%= u.UnitNumber %></strong></td>
              <td><%= property.PropertyName || 'N/A' %></td>
              <td><%= u.UnitType || 'Standard' %></td>
              <td>$<%= parseFloat(u.RentAmount).toFixed(2) %></td>
              <td><span class="badge <%= u.Status === 'Occupied' ? 'badge-success' : (u.Status === 'Vacant' ? 'badge-warning' : 'badge-danger') %>"><%= u.Status %></span></td>
              <td class="actions">
                <button class="btn-small" onclick="editUnit('<%= u.UnitID %>', '<%= u.PropertyID %>', '<%= u.UnitNumber %>', '<%= u.UnitType %>', '<%= u.RentAmount %>', '<%= u.Status %>')">✏️</button>
                <form action="/units/<%= u.UnitID %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Delete this unit?')">
                  <button type="submit" class="btn-small btn-danger">🗑️</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mobile-cards">
      <% units.forEach(u => {
        const property = properties.find(p => p.PropertyID === u.PropertyID) || {};
      %>
        <div class="card">
          <div class="card-header">
            <h3>Unit <%= u.UnitNumber %></h3>
            <span class="badge <%= u.Status === 'Occupied' ? 'badge-success' : (u.Status === 'Vacant' ? 'badge-warning' : 'badge-danger') %>"><%= u.Status %></span>
          </div>
          <p>🏢 <%= property.PropertyName || 'N/A' %></p>
          <p>🏷️ <%= u.UnitType || 'Standard' %></p>
          <p>💵 $<%= parseFloat(u.RentAmount).toFixed(2) %></p>
          <div class="card-actions">
            <button class="btn-small" onclick="editUnit('<%= u.UnitID %>', '<%= u.PropertyID %>', '<%= u.UnitNumber %>', '<%= u.UnitType %>', '<%= u.RentAmount %>', '<%= u.Status %>')">✏️ Edit</button>
            <form action="/units/<%= u.UnitID %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Delete?')">
              <button type="submit" class="btn-small btn-danger">🗑️</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty">No units found. Add your first unit.</p>
  <% } %>
</div>

<div id="addModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('addModal')">&times;</span>
    <h2>Add Unit</h2>
    <form action="/units" method="POST">
      <div class="form-group"><label>Property</label>
        <select name="propertyId" required>
          <option value="">Select Property</option>
          <% properties.filter(p => p.Status === 'Active').forEach(p => { %>
            <option value="<%= p.PropertyID %>"><%= p.PropertyName %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group"><label>Unit Number</label><input type="text" name="unitNumber" required placeholder="e.g. 101, A1"></div>
      <div class="form-group"><label>Unit Type</label>
        <select name="unitType">
          <option value="Standard">Standard</option>
          <option value="Studio">Studio</option>
          <option value="Penthouse">Penthouse</option>
          <option value="Office">Office</option>
        </select>
      </div>
      <div class="form-group"><label>Monthly Rent ($)</label><input type="number" name="rentAmount" step="0.01" required></div>
      <button type="submit" class="btn btn-primary">Save Unit</button>
    </form>
  </div>
</div>

<div id="editModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('editModal')">&times;</span>
    <h2>Edit Unit</h2>
    <form id="editForm" method="POST">
      <input type="hidden" name="_method" value="PUT">
      <div class="form-group"><label>Property</label>
        <select name="propertyId" id="editProperty" required>
          <% properties.filter(p => p.Status === 'Active').forEach(p => { %>
            <option value="<%= p.PropertyID %>"><%= p.PropertyName %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group"><label>Unit Number</label><input type="text" name="unitNumber" id="editNumber" required></div>
      <div class="form-group"><label>Unit Type</label>
        <select name="unitType" id="editType">
          <option value="Standard">Standard</option>
          <option value="Studio">Studio</option>
          <option value="Penthouse">Penthouse</option>
          <option value="Office">Office</option>
        </select>
      </div>
      <div class="form-group"><label>Monthly Rent ($)</label><input type="number" name="rentAmount" id="editRent" step="0.01" required></div>
      <div class="form-group"><label>Status</label>
        <select name="status" id="editStatus">
          <option value="Vacant">Vacant</option>
          <option value="Occupied">Occupied</option>
          <option value="Maintenance">Maintenance</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">Update Unit</button>
    </form>
  </div>
</div>

<script>
function editUnit(id, propertyId, number, type, rent, status) {
  document.getElementById('editForm').action = '/units/' + id;
  document.getElementById('editProperty').value = propertyId;
  document.getElementById('editNumber').value = number;
  document.getElementById('editType').value = type || 'Standard';
  document.getElementById('editRent').value = rent;
  document.getElementById('editStatus').value = status || 'Vacant';
  openModal('editModal');
}
</script>