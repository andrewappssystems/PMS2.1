<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ManageMate — Dashboard</title>
  <link rel="stylesheet" href="/css/design-system.css">
  <style>
    /* Dashboard Specific Styles */
    .page-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: var(--space-4);
      margin-bottom: var(--section-gap);
    }

    .page-header h1 {
      margin-bottom: 0;
    }

    .page-header-meta {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .quick-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: var(--card-gap);
      margin-bottom: var(--section-gap);
    }

    .dashboard-section {
      margin-bottom: var(--section-gap);
    }

    .dashboard-section h2 {
      font-size: var(--font-size-xl);
      font-weight: var(--font-weight-semibold);
      margin-bottom: var(--space-6);
    }

    .cards-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--card-gap);
      margin-bottom: var(--card-gap);
    }

    .stat-metric {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: var(--space-4);
    }

    .metric-value {
      font-size: 40px;
      font-weight: var(--font-weight-extrabold);
      color: var(--color-primary);
      line-height: 1;
    }

    .metric-label {
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      text-transform: uppercase;
      font-weight: var(--font-weight-semibold);
      letter-spacing: 0.05em;
    }

    .metric-change {
      display: inline-block;
      padding: var(--space-1) var(--space-2);
      border-radius: var(--radius-md);
      font-size: var(--font-size-xs);
      font-weight: var(--font-weight-semibold);
    }

    .metric-change.positive {
      background-color: var(--color-success-light);
      color: var(--color-success);
    }

    .metric-change.negative {
      background-color: var(--color-error-light);
      color: var(--color-error);
    }

    .recent-transactions {
      background-color: var(--color-white);
      border-radius: var(--radius-2xl);
      border: 1px solid var(--color-border-light);
      overflow: hidden;
      box-shadow: var(--shadow-lg);
    }

    .transaction-row {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-4);
      border-bottom: 1px solid var(--color-border-light);
      transition: background-color var(--transition-base);
    }

    .transaction-row:hover {
      background-color: var(--color-surface);
    }

    .transaction-row:last-child {
      border-bottom: none;
    }

    .transaction-icon {
      width: 40px;
      height: 40px;
      border-radius: var(--radius-md);
      background-color: var(--color-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }

    .transaction-details {
      flex: 1;
      min-width: 0;
    }

    .transaction-title {
      font-weight: var(--font-weight-semibold);
      color: var(--color-text);
      margin-bottom: var(--space-1);
    }

    .transaction-meta {
      font-size: var(--font-size-xs);
      color: var(--color-text-muted);
    }

    .transaction-amount {
      font-size: var(--font-size-sm);
      font-weight: var(--font-weight-bold);
      text-align: right;
      white-space: nowrap;
    }

    .action-row {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      flex-wrap: wrap;
    }

    .action-button {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-4);
      background-color: var(--color-primary);
      color: var(--color-white);
      border-radius: var(--radius-md);
      font-weight: var(--font-weight-semibold);
      font-size: var(--font-size-sm);
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: all var(--transition-base);
    }

    .action-button:hover {
      background-color: var(--color-primary-dark);
      transform: translateY(-2px);
    }

    .quick-actions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: var(--space-4);
      margin-top: var(--space-6);
    }

    /* Mobile Adjustments */
    @media (max-width: 768px) {
      .page-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .quick-stats {
        grid-template-columns: repeat(2, 1fr);
      }

      .cards-row {
        grid-template-columns: 1fr;
      }

      .action-row {
        flex-direction: column;
        width: 100%;
      }

      .action-row .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <!-- Sidebar Navigation -->
    <aside class="sidebar">
      <div class="sidebar-logo">
        <div class="sidebar-logo-icon">🏢</div>
        <div class="sidebar-logo-text">ManageMate</div>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-section">Management</div>
        <a href="#" class="nav-link active">
          <span class="nav-icon">📊</span>
          Dashboard
        </a>
        <a href="#" class="nav-link">
          <span class="nav-icon">🏘️</span>
          Properties
        </a>
        <a href="#" class="nav-link">
          <span class="nav-icon">🚪</span>
          Units
        </a>
        <a href="#" class="nav-link">
          <span class="nav-icon">👥</span>
          Tenants
        </a>

        <div class="nav-section">Finance</div>
        <a href="#" class="nav-link">
          <span class="nav-icon">💰</span>
          Rent Collection
        </a>
        <a href="#" class="nav-link">
          <span class="nav-icon">📑</span>
          Expenses
        </a>
        <a href="#" class="nav-link">
          <span class="nav-icon">📄</span>
          Invoices
        </a>

        <div class="nav-section">Portfolio</div>
        <a href="#" class="nav-link">
          <span class="nav-icon">👤</span>
          Landlords
        </a>
        <a href="#" class="nav-link">
          <span class="nav-icon">📈</span>
          Reports
        </a>

        <div class="nav-section">Admin</div>
        <a href="#" class="nav-link">
          <span class="nav-icon">⚙️</span>
          Settings
        </a>
        <a href="/logout" class="nav-link">
          <span class="nav-icon">🚪</span>
          Sign Out
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
          <div class="user-details">
            <div class="user-name"><%= user.name %></div>
            <div class="user-role"><%= user.role %></div>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="main">
      <!-- Header -->
      <header class="header">
        <div>
          <h1>Dashboard</h1>
          <p style="font-size: var(--font-size-xs); color: var(--color-text-muted); margin-top: var(--space-2);">Welcome back, <%= user.name %></p>
        </div>
        <div style="display: flex; align-items: center; gap: var(--space-4);">
          <span style="font-size: var(--font-size-sm); color: var(--color-text-muted);">
            <span id="current-date"></span>
          </span>
        </div>
      </header>

      <!-- Content -->
      <div class="content">
        <!-- Page Header -->
        <div class="page-header">
          <div>
            <h1>Property Management Overview</h1>
            <div class="page-header-meta">
              <span>Real-time portfolio insights</span>
            </div>
          </div>
          <div class="action-row">
            <button class="action-button">+ Add Property</button>
            <button class="action-button" style="background-color: transparent; color: var(--color-primary); border: 1px solid var(--color-primary);">View All</button>
          </div>
        </div>

        <!-- Quick Stats / KPI Cards -->
        <div class="quick-stats">
          <div class="kpi-card">
            <div class="kpi-label">Active Properties</div>
            <div class="kpi-value">24</div>
            <div class="kpi-meta">↑ 2 from last month</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">Occupied Units</div>
            <div class="kpi-value" style="color: var(--color-success);">156</div>
            <div class="kpi-meta">89% occupancy rate</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">Monthly Revenue</div>
            <div class="kpi-value">UGX 45.2M</div>
            <div class="kpi-meta">↑ 12% vs last month</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label">Outstanding Balance</div>
            <div class="kpi-value" style="color: var(--color-error);">UGX 3.8M</div>
            <div class="kpi-meta">18 tenants in arrears</div>
          </div>
        </div>

        <!-- Alert Section -->
        <% if (false) { %>
          <div class="alert alert-warning" style="margin-bottom: var(--section-gap);">
            <strong>⚠️ Action Required:</strong>
            3 lease agreements expire within 30 days
          </div>
        <% } %>

        <!-- Key Metrics Section -->
        <div class="dashboard-section">
          <h2>Key Metrics</h2>
          <div class="cards-row">
            <div class="card">
              <div class="stat-metric">
                <div>
                  <div class="metric-label">Total Landlords</div>
                  <div class="metric-value">12</div>
                </div>
                <div class="metric-change positive">↑ 1</div>
              </div>
            </div>
            <div class="card">
              <div class="stat-metric">
                <div>
                  <div class="metric-label">Total Tenants</div>
                  <div class="metric-value">156</div>
                </div>
                <div class="metric-change positive">↑ 4</div>
              </div>
            </div>
            <div class="card">
              <div class="stat-metric">
                <div>
                  <div class="metric-label">Vacant Units</div>
                  <div class="metric-value">19</div>
                </div>
                <div class="metric-change negative">↑ 2</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Transactions -->
        <div class="dashboard-section">
          <h2>Recent Rent Payments</h2>
          <div class="recent-transactions">
            <div class="transaction-row">
              <div class="transaction-icon">💰</div>
              <div class="transaction-details">
                <div class="transaction-title">Rent Payment - Lakeview Apartments Unit 12</div>
                <div class="transaction-meta">June 15, 2026 • John Doe</div>
              </div>
              <div class="transaction-amount" style="color: var(--color-success);">+UGX 1,250,000</div>
            </div>
            <div class="transaction-row">
              <div class="transaction-icon">💰</div>
              <div class="transaction-details">
                <div class="transaction-title">Rent Payment - Downtown Complex Unit 5</div>
                <div class="transaction-meta">June 15, 2026 • Jane Smith</div>
              </div>
              <div class="transaction-amount" style="color: var(--color-success);">+UGX 950,000</div>
            </div>
            <div class="transaction-row">
              <div class="transaction-icon">📑</div>
              <div class="transaction-details">
                <div class="transaction-title">Expense - Property Maintenance</div>
                <div class="transaction-meta">June 14, 2026 • System</div>
              </div>
              <div class="transaction-amount" style="color: var(--color-error);">-UGX 450,000</div>
            </div>
            <div class="transaction-row">
              <div class="transaction-icon">💰</div>
              <div class="transaction-details">
                <div class="transaction-title">Management Fee Invoice - Monthly</div>
                <div class="transaction-meta">June 1, 2026 • System</div>
              </div>
              <div class="transaction-amount">UGX 500,000</div>
            </div>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="dashboard-section">
          <h2>Quick Actions</h2>
          <div class="quick-actions-grid">
            <button class="btn btn-primary">+ Record Rent Payment</button>
            <button class="btn btn-primary">+ Add Expense</button>
            <button class="btn btn-secondary">+ Create Invoice</button>
            <button class="btn btn-secondary">+ Add Tenant</button>
          </div>
        </div>

        <!-- Upcoming Tasks -->
        <div class="dashboard-section">
          <h2>Upcoming Tasks</h2>
          <div class="card">
            <div style="display: grid; gap: var(--space-4);">
              <div style="display: flex; align-items: flex-start; gap: var(--space-3); padding: var(--space-4); background-color: var(--color-primary-lighter); border-radius: var(--radius-lg);">
                <span style="font-size: 20px;">📅</span>
                <div>
                  <div style="font-weight: var(--font-weight-semibold);">Lease Renewal - Lakeview Unit 5</div>
                  <div style="font-size: var(--font-size-xs); color: var(--color-text-muted); margin-top: var(--space-1);">Due: June 28, 2026</div>
                </div>
              </div>
              <div style="display: flex; align-items: flex-start; gap: var(--space-3); padding: var(--space-4); background-color: var(--color-warning-light); border-radius: var(--radius-lg);">
                <span style="font-size: 20px;">⚠️</span>
                <div>
                  <div style="font-weight: var(--font-weight-semibold);">Rent Arrears - 3 Units Outstanding</div>
                  <div style="font-size: var(--font-size-xs); color: var(--color-text-muted); margin-top: var(--space-1);">Action Required</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Update current date
    const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    const today = new Date().toLocaleDateString('en-US', options);
    document.getElementById('current-date').textContent = today;

    // Load actual data via API
    async function loadStats() {
      try {
        const response = await fetch('/api/stats');
        const data = await response.json();
        // Update UI with data
        console.log('Stats loaded:', data);
      } catch (error) {
        console.error('Error loading stats:', error);
      }
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', loadStats);
  </script>
</body>
</html>
