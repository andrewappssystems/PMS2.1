<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>PMS — Dashboard</title>
<style>
:root{--primary:#0f766e;--primary-dark:#0d5c56;--danger:#ef4444;--success:#22c55e;--warning:#f59e0b;--bg:#f1f5f9;--card:#fff;--text:#0f172a;--text-light:#64748b;--border:#e2e8f0;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
.app{display:flex;min-height:100vh;}
.sidebar{width:260px;background:var(--primary-dark);color:#fff;position:fixed;height:100vh;overflow-y:auto;z-index:100;transition:transform .3s;}
.sidebar .logo{padding:20px;font-size:18px;font-weight:700;border-bottom:1px solid rgba(255,255,255,.1);display:flex;align-items:center;gap:10px;}
.sidebar .logo img{width:36px;height:36px;object-fit:contain;border-radius:6px;}
.sidebar .logo .logo-icon{font-size:28px;}
.sidebar nav{padding:12px 0;}
.sidebar nav a{display:flex;align-items:center;gap:12px;padding:12px 20px;color:rgba(255,255,255,.8);text-decoration:none;font-size:14px;font-weight:500;transition:.2s;cursor:pointer;}
.sidebar nav a:hover,.sidebar nav a.active{background:rgba(255,255,255,.1);color:#fff;}
.sidebar .nav-section{padding:8px 20px 4px;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:rgba(255,255,255,.4);font-weight:700;}
.sidebar .user-info{position:absolute;bottom:0;left:0;right:0;padding:16px 20px;border-top:1px solid rgba(255,255,255,.1);background:var(--primary-dark);}
.sidebar .user-info .name{font-weight:600;font-size:14px;}
.sidebar .user-info .role{font-size:12px;color:rgba(255,255,255,.6);}
.sidebar .user-info .logout{margin-top:8px;font-size:12px;color:#fca5a5;cursor:pointer;background:none;border:none;}
.main{flex:1;margin-left:260px;min-height:100vh;}
.topbar{background:var(--card);padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50;}
.topbar h1{font-size:20px;font-weight:700;}
.topbar .date{color:var(--text-light);font-size:14px;}
.topbar .mobile-menu{display:none;background:none;border:none;font-size:24px;cursor:pointer;}
.content{padding:24px;}
/* Stats */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:24px;}
.stat-card{background:var(--card);border-radius:12px;padding:20px;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.stat-card .label{font-size:12px;color:var(--text-light);text-transform:uppercase;font-weight:600;letter-spacing:.5px;}
.stat-card .value{font-size:26px;font-weight:700;margin-top:4px;color:var(--primary);}
.stat-card.danger .value{color:var(--danger);}
.stat-card.warning .value{color:var(--warning);}
/* Critical arrears widget */
.arrears-widget{background:var(--card);border-radius:12px;padding:20px;box-shadow:0 1px 3px rgba(0,0,0,.05);margin-bottom:24px;}
.arrears-widget h3{font-size:15px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.arrears-widget .arrears-list{display:flex;flex-direction:column;gap:8px;}
.arrears-item{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:#fef2f2;border-radius:8px;border-left:3px solid var(--danger);}
.arrears-item .ai-info{font-size:13px;font-weight:600;}
.arrears-item .ai-sub{font-size:12px;color:var(--text-light);}
.arrears-item .ai-amt{font-size:14px;font-weight:700;color:var(--danger);}
/* Quick actions */
.quick-actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:24px;}
.quick-actions button{padding:10px 20px;border-radius:8px;border:none;background:var(--primary);color:#fff;font-weight:600;font-size:14px;cursor:pointer;transition:.2s;white-space:nowrap;}
.quick-actions button:hover{background:var(--primary-dark);}
.quick-actions button.secondary{background:var(--card);color:var(--primary);border:1px solid var(--primary);}
/* Tables */
.data-table{background:var(--card);border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.table-header{padding:16px 20px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:12px;}
.table-header h3{font-size:16px;font-weight:700;}
.table-header .search{padding:8px 14px;border:1px solid var(--border);border-radius:8px;font-size:14px;width:240px;}
table{width:100%;border-collapse:collapse;font-size:14px;}
th{text-align:left;padding:12px 20px;background:#f8fafc;font-size:12px;text-transform:uppercase;color:var(--text-light);font-weight:600;white-space:nowrap;}
td{padding:12px 20px;border-bottom:1px solid var(--border);}
tr:hover{background:#f8fafc;}
.badge{display:inline-block;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;text-transform:uppercase;}
.badge.success{background:#dcfce7;color:#166534;}
.badge.danger{background:#fee2e2;color:#991b1b;}
.badge.warning{background:#fef3c7;color:#92400e;}
.badge.info{background:#dbeafe;color:#1e40af;}
.actions{display:flex;gap:6px;flex-wrap:wrap;}
.actions button{padding:5px 10px;border-radius:6px;border:none;font-size:12px;font-weight:600;cursor:pointer;}
.btn-edit{background:#dbeafe;color:#1e40af;}
.btn-delete{background:#fee2e2;color:#991b1b;}
.btn-view{background:#f3f4f6;color:#374151;}
.btn-receipt{background:#dcfce7;color:#166534;}
.btn-pwd{background:#fef3c7;color:#92400e;}
.empty-state{text-align:center;padding:50px 20px;}
.empty-state .icon{font-size:40px;margin-bottom:12px;}
.empty-state h3{font-size:16px;color:var(--text-light);}
/* Pagination */
.pagination{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-top:1px solid var(--border);font-size:13px;color:var(--text-light);}
.pg-btns{display:flex;gap:6px;}
.pg-btns button{padding:6px 12px;border:1px solid var(--border);border-radius:6px;background:var(--card);font-size:13px;cursor:pointer;}
.pg-btns button:hover:not(:disabled){background:var(--primary);color:#fff;border-color:var(--primary);}
.pg-btns button:disabled{opacity:.4;cursor:not-allowed;}
.pg-btns button.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.loading-row td{text-align:center;padding:40px;color:var(--text-light);}
.spinner{display:inline-block;width:18px;height:18px;border:2px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle;margin-right:6px;}
@keyframes spin{to{transform:rotate(360deg)}}
/* Modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:center;justify-content:center;padding:20px;}
.modal-overlay.active{display:flex;}
.modal{background:var(--card);border-radius:16px;width:100%;max-width:580px;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2);}
.modal.wide{max-width:720px;}
.modal-header{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:var(--card);z-index:1;}
.modal-header h2{font-size:18px;font-weight:700;}
.modal-header .close{background:none;border:none;font-size:24px;color:var(--text-light);cursor:pointer;}
.modal-body{padding:24px;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-group.full{grid-column:1/-1;}
.form-group label{font-size:12px;font-weight:600;color:var(--text-light);text-transform:uppercase;letter-spacing:.3px;}
.form-group input,.form-group select,.form-group textarea{padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-size:14px;font-family:inherit;outline:none;}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--primary);}
.form-group textarea{min-height:70px;resize:vertical;}
.modal-footer{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:12px;position:sticky;bottom:0;background:var(--card);}
.modal-footer button{padding:10px 20px;border-radius:8px;font-weight:600;font-size:14px;cursor:pointer;border:none;}
.btn-cancel{background:var(--bg);color:var(--text);}
.btn-save{background:var(--primary);color:#fff;}
/* Bulk unit preview */
.unit-preview{background:#f8fafc;border:1px solid var(--border);border-radius:8px;padding:14px;max-height:160px;overflow-y:auto;margin-top:8px;}
.unit-preview .preview-tag{display:inline-block;background:#dbeafe;color:#1e40af;padding:3px 8px;border-radius:4px;font-size:12px;margin:3px;}
/* Settings form */
.settings-form{display:flex;flex-direction:column;gap:0;}
.settings-row{display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-bottom:1px solid var(--border);gap:20px;}
.settings-row label{font-size:14px;font-weight:600;min-width:160px;}
.settings-row input{flex:1;padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:14px;outline:none;}
.settings-row input:focus{border-color:var(--primary);}
.settings-row input[readonly]{background:#f8fafc;color:var(--text-light);}
.logo-preview{width:80px;height:80px;object-fit:contain;border-radius:8px;border:1px solid var(--border);background:#f8fafc;}
.logo-placeholder{width:80px;height:80px;border-radius:8px;border:2px dashed var(--border);display:flex;align-items:center;justify-content:center;font-size:24px;color:var(--text-light);}
/* Section */
.section{display:none;}
.section.active{display:block;}
.section-title{font-size:24px;font-weight:700;margin-bottom:20px;}
/* Toast */
.toast{position:fixed;bottom:24px;right:24px;padding:14px 24px;border-radius:10px;color:#fff;font-weight:600;font-size:14px;z-index:400;transform:translateY(100px);opacity:0;transition:.3s;max-width:320px;}
.toast.show{transform:translateY(0);opacity:1;}
.toast.success{background:var(--success);}
.toast.error{background:var(--danger);}
/* Prompt */
.prompt-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;align-items:center;justify-content:center;padding:20px;}
.prompt-overlay.active{display:flex;}
.prompt-box{background:var(--card);border-radius:16px;padding:32px;max-width:400px;width:100%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.2);}
.prompt-box h3{font-size:18px;margin-bottom:10px;}
.prompt-box p{color:var(--text-light);margin-bottom:24px;font-size:14px;}
.prompt-buttons{display:flex;gap:12px;justify-content:center;}
.prompt-buttons button{padding:10px 24px;border-radius:8px;font-weight:600;cursor:pointer;border:none;}
.btn-yes{background:var(--primary);color:#fff;}
.btn-no{background:var(--bg);color:var(--text);}
@media(max-width:768px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:translateX(0);}
  .main{margin-left:0;}
  .topbar .mobile-menu{display:block;}
  .stats-grid{grid-template-columns:repeat(2,1fr);}
  .form-grid{grid-template-columns:1fr;}
  .data-table{overflow-x:auto;}
  table{min-width:600px;}
  .quick-actions{overflow-x:auto;flex-wrap:nowrap;padding-bottom:8px;}
  .modal{max-height:95vh;}
  .table-header{flex-direction:column;align-items:flex-start!important;}
  .table-header .search{width:100%!important;}
  .settings-row{flex-direction:column;align-items:flex-start;}
}
</style>
</head>
<body>
<div class="app">
  <aside class="sidebar" id="sidebar">
    <div class="logo" id="sidebarLogo">
      <span class="logo-icon">🏢</span>
      <span id="logoCompanyName">PMS</span>
    </div>
    <nav>
      <a class="active" onclick="showSection('dashboard',event)">📊 Dashboard</a>
      <div class="nav-section">Portfolio</div>
      <a onclick="showSection('landlords',event)">👤 Landlords</a>
      <a onclick="showSection('properties',event)">🏘️ Properties</a>
      <a onclick="showSection('units',event)">🚪 Units</a>
      <div class="nav-section">Leasing</div>
      <a onclick="showSection('tenants',event)">👥 Tenants</a>
      <a onclick="showSection('rent',event)">💰 Rent Collection</a>
      <a onclick="showSection('arrears',event)">⚠️ Arrears</a>
      <div class="nav-section">Finance</div>
      <a onclick="showSection('expenses',event)">📑 Expenses</a>
      <a onclick="showSection('invoices',event)">📄 Invoices</a>
      <a onclick="showSection('receipts',event)">🧾 Receipts</a>
      <div class="nav-section" id="navAdminLabel">Admin</div>
      <a onclick="showSection('users',event)" id="navUsers">🔐 Users</a>
      <a onclick="showSection('settings',event)" id="navSettings">⚙️ Settings</a>
      <div class="nav-section">Reports</div>
      <a onclick="showSection('reports',event)">📈 Reports</a>
      <a onclick="showSection('archive',event)" id="navArchive">🗃️ Archive</a>
    </nav>
    <div class="user-info">
      <div class="name" id="userName">Loading...</div>
      <div class="role" id="userRole">...</div>
      <button class="logout" onclick="logout()">🚪 Sign Out</button>
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <button class="mobile-menu" onclick="toggleSidebar()">☰</button>
      <h1 id="pageTitle">Dashboard</h1>
      <div class="date" id="dashDate"></div>
    </div>
  <div class="section" id="sec-reports">
  <div class="section-title">Reports</div>
  <div class="quick-actions">
    <button onclick="openReportModal('portfolio')">📊 Portfolio Report</button>
    <button onclick="openReportModal('landlord')">👤 Landlord Report</button>
    <button onclick="openReportModal('tenant')">👥 Tenant Statement</button>
    <button class="secondary" onclick="openBulkInvoiceModal()">📄 Bulk Invoices</button>
  </div>
   <div class="section" id="sec-archive">
  <div class="section-title">Deleted Records Archive</div>
  <div class="data-table">
    <div class="table-header">
      <h3>Archive</h3>
      <div style="display:flex;gap:8px">
        <select id="archiveTypeFilter" onchange="loadArchive()" style="padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px">
          <option value="">All types</option>
          <option value="tenant">Tenants</option>
          <option value="landlord">Landlords</option>
        </select>
        <input id="archiveSearch" class="search" placeholder="Search by name..." oninput="loadArchive()" style="width:200px">
      </div>
    </div>
    <table><thead><tr><th>Deleted At</th><th>Type</th><th>ID</th><th>Name</th><th>Deleted By</th></tr></thead>
    <tbody id="archiveTable"><tr><td colspan="5" style="text-align:center;padding:30px;color:var(--text-light)">Select a filter or search to load archive</td></tr></tbody></table>
  </div>
</div>
    <div class="content">

      <!-- ── DASHBOARD ── -->
      <div class="section active" id="sec-dashboard">
        <div class="stats-grid">
          <div class="stat-card"><div class="label">Landlords</div><div class="value" id="statLandlords">—</div></div>
          <div class="stat-card"><div class="label">Properties</div><div class="value" id="statProperties">—</div></div>
          <div class="stat-card"><div class="label">Units</div><div class="value" id="statUnits">—</div></div>
          <div class="stat-card"><div class="label">Tenants</div><div class="value" id="statTenants">—</div></div>
          <div class="stat-card"><div class="label">Occupied</div><div class="value" id="statOccupied">—</div></div>
          <div class="stat-card warning"><div class="label">Vacant</div><div class="value" id="statVacant">—</div></div>
          <div class="stat-card"><div class="label">Total Rent Collected</div><div class="value" id="statRent">—</div></div>
          <div class="stat-card"><div class="label">Total Expenses</div><div class="value" id="statExpenses">—</div></div>
          <div class="stat-card danger"><div class="label">Total Arrears</div><div class="value" id="statArrears">—</div></div>
          <div class="stat-card danger"><div class="label">Tenants in Arrears</div><div class="value" id="statArrearsCount">—</div></div>
        </div>
        <!-- Critical Arrears Widget -->
        <div class="arrears-widget" id="criticalArrearsWidget" style="display:none">
          <h3>🚨 Critical Arrears <span id="criticalArrearsSubtitle" style="font-size:13px;font-weight:400;color:var(--text-light)"></span></h3>
          <div class="arrears-list" id="criticalArrearsList"></div>
          <div style="margin-top:12px"><button class="secondary" style="padding:8px 16px;border-radius:8px;border:1px solid var(--primary);background:var(--card);color:var(--primary);font-weight:600;font-size:13px;cursor:pointer" onclick="showSection('arrears',event)">View All Arrears →</button></div>
        </div>
        <div class="quick-actions">
          <button onclick="openModal('landlord')">+ Add Landlord</button>
          <button onclick="openModal('property')">+ Add Property</button>
          <button onclick="openModal('unit')">+ Add Unit</button>
          <button onclick="openModal('tenant')">+ Add Tenant</button>
          <button class="secondary" onclick="openModal('rent')">+ Record Rent</button>
          <button class="secondary" onclick="openModal('expense')">+ Add Expense</button>
          <button class="secondary" onclick="openModal('invoice')">+ Create Invoice</button>
        </div>
      </div>

      <!-- ── LANDLORDS ── -->
      <div class="section" id="sec-landlords">
        <div class="section-title">Landlords</div>
        <div class="quick-actions"><button onclick="openModal('landlord')">+ Add Landlord</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Landlords</h3><input class="search" placeholder="Search..." oninput="filterTable('landlordsTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Email</th><th>Commission</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="landlordsTable"><tr class="loading-row"><td colspan="7"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- ── PROPERTIES ── -->
      <div class="section" id="sec-properties">
        <div class="section-title">Properties</div>
        <div class="quick-actions"><button onclick="openModal('property')">+ Add Property</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Properties</h3><input class="search" placeholder="Search..." oninput="filterTable('propertiesTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Landlord</th><th>Address</th><th>Type</th><th>Units</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="propertiesTable"><tr class="loading-row"><td colspan="8"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- ── UNITS ── -->
      <div class="section" id="sec-units">
        <div class="section-title">Units</div>
        <div class="quick-actions">
          <button onclick="openModal('unit')">+ Add Unit</button>
          <button class="secondary" onclick="openModal('bulk_unit')">+ Add Units in Bulk</button>
        </div>
        <div class="data-table">
          <div class="table-header"><h3>All Units</h3><input class="search" placeholder="Search..." oninput="filterTable('unitsTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Property</th><th>Unit No.</th><th>Type</th><th>Rent (UGX)</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="unitsTable"><tr class="loading-row"><td colspan="7"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- ── TENANTS ── -->
      <div class="section" id="sec-tenants">
        <div class="section-title">Tenants</div>
        <div class="quick-actions"><button onclick="openModal('tenant')">+ Add Tenant</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Tenants</h3><input class="search" placeholder="Search..." oninput="filterTable('tenantsTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Unit</th><th>Rent (UGX)</th><th>Lease End</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="tenantsTable"><tr class="loading-row"><td colspan="8"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- ── RENT ── -->
      <div class="section" id="sec-rent">
        <div class="section-title">Rent Collection</div>
        <div class="quick-actions"><button onclick="openModal('rent')">+ Record Payment</button></div>
        <div class="data-table">
          <div class="table-header"><h3>Payment History</h3><input class="search" placeholder="Search..." oninput="filterTable('rentTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Tenant</th><th>Unit</th><th>Amount (UGX)</th><th>Period</th><th>Method</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody id="rentTable"><tr class="loading-row"><td colspan="8"><span class="spinner"></span>Loading…</td></tr></tbody></table>
          <div class="pagination" id="rentPagination" style="display:none"></div>
        </div>
      </div>

      <!-- ── ARREARS ── -->
      <div class="section" id="sec-arrears">
        <div class="section-title">Arrears</div>
        <div class="data-table">
          <div class="table-header"><h3>Outstanding Rent</h3></div>
          <table><thead><tr><th>Tenant</th><th>Unit</th><th>Monthly Rent</th><th>Months Due</th><th>Total Due (UGX)</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="arrearsTable"><tr class="loading-row"><td colspan="7"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- ── EXPENSES ── -->
      <div class="section" id="sec-expenses">
        <div class="section-title">Expenses</div>
        <div class="quick-actions"><button onclick="openModal('expense')">+ Add Expense</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Expenses</h3><input class="search" placeholder="Search..." oninput="filterTable('expensesTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Property</th><th>Category</th><th>Description</th><th>Amount (UGX)</th><th>Date</th><th>Actions</th></tr></thead>
