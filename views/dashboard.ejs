// ── Arrears ───────────────────────────────────────────────────────────────────
function loadArrears(){
  const tb=document.getElementById('arrearsTable');
  const activeTenants=tenants.filter(t=>isActive(t));
  const now=new Date(); const arrears=[];
  activeTenants.forEach(t=>{
    const u=units.find(x=>un.id(x)===tn.unit(t));
    const rentAmt=parseFloat(tn.rent(t))||0; if(!rentAmt) return;
    const leaseStart=tn.start(t)?new Date(tn.start(t)):null; if(!leaseStart) return;
    const paid=new Set(rentData.filter(r=>rn.tenant(r)===tn.id(t)).map(r=>`${rn.year(r)}-${rn.month(r)}`));
    let due=0; const check=new Date(leaseStart); check.setMonth(check.getMonth()+1);
    while(check<=now){ const ym=`${check.getFullYear()}-${String(check.getMonth()+1).padStart(2,'0')}`; if(!paid.has(ym)) due++; check.setMonth(check.getMonth()+1); }
    if(due>0) arrears.push({t,u,rent:rentAmt,months:due,total:rentAmt*due});
  });
  if(!arrears.length){ tb.innerHTML=empty(6,'✅','All tenants are up to date'); return; }
  tb.innerHTML=arrears.map(a=>`<tr>
    <td>${tn.name(a.t)}</td><td>${a.u?un.num(a.u):'N/A'}</td>
    <td>${a.rent.toLocaleString()}</td><td>${a.months}</td>
    <td style="color:var(--danger);font-weight:700">${a.total.toLocaleString()}</td>
    <td class="actions"><button class="btn-edit" onclick="openModal('rent',null,'${tn.id(a.t)}')">Record Payment</button></td>
  </tr>`).join('');
}

