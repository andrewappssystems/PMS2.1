<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>PMS — Dashboard</title>
<style>
:root{--primary:#0f766e;--primary-light:#14b8a6;--primary-dark:#0d5c56;--danger:#ef4444;--success:#22c55e;--warning:#f59e0b;--bg:#f1f5f9;--card:#fff;--text:#0f172a;--text-light:#64748b;--border:#e2e8f0;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
.app{display:flex;min-height:100vh;}
.sidebar{width:260px;background:var(--primary-dark);color:#fff;position:fixed;height:100vh;overflow-y:auto;z-index:100;transition:transform .3s;}
.sidebar .logo{padding:24px 20px;font-size:20px;font-weight:700;border-bottom:1px solid rgba(255,255,255,.1);display:flex;align-items:center;gap:10px;}
.sidebar .logo span{font-size:28px;}
.sidebar nav{padding:12px 0;}
.sidebar nav a{display:flex;align-items:center;gap:12px;padding:12px 20px;color:rgba(255,255,255,.8);text-decoration:none;font-size:14px;font-weight:500;transition:.2s;cursor:pointer;}
.sidebar nav a:hover,.sidebar nav a.active{background:rgba(255,255,255,.1);color:#fff;}
.sidebar .nav-section{padding:8px 20px 4px;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:rgba(255,255,255,.4);font-weight:700;}
.sidebar .user{position:absolute;bottom:0;left:0;right:0;padding:16px 20px;border-top:1px solid rgba(255,255,255,.1);background:var(--primary-dark);}
.sidebar .user .name{font-weight:600;font-size:14px;}
.sidebar .user .role{font-size:12px;color:rgba(255,255,255,.6);}
.sidebar .user .logout{margin-top:8px;font-size:12px;color:#fca5a5;cursor:pointer;background:none;border:none;}
.main{flex:1;margin-left:260px;min-height:100vh;}
.topbar{background:var(--card);padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50;}
.topbar h1{font-size:20px;font-weight:700;}
.topbar .date{color:var(--text-light);font-size:14px;}
.topbar .mobile-menu{display:none;background:none;border:none;font-size:24px;cursor:pointer;}
.content{padding:24px;}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:24px;}
.stat-card{background:var(--card);border-radius:12px;padding:20px;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.stat-card .label{font-size:12px;color:var(--text-light);text-transform:uppercase;font-weight:600;letter-spacing:.5px;}
.stat-card .value{font-size:28px;font-weight:700;margin-top:4px;color:var(--primary);}
.quick-actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:24px;}
.quick-actions button{padding:10px 20px;border-radius:8px;border:none;background:var(--primary);color:#fff;font-weight:600;font-size:14px;cursor:pointer;transition:.2s;}
.quick-actions button:hover{background:var(--primary-dark);}
.quick-actions button.secondary{background:var(--card);color:var(--primary);border:1px solid var(--primary);}
.data-table{background:var(--card);border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.data-table .table-header{padding:16px 20px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:12px;}
.data-table .table-header h3{font-size:16px;font-weight:700;}
.data-table .table-header .search{padding:8px 14px;border:1px solid var(--border);border-radius:8px;font-size:14px;width:240px;}
.data-table table{width:100%;border-collapse:collapse;font-size:14px;}
.data-table th{text-align:left;padding:12px 20px;background:#f8fafc;font-size:12px;text-transform:uppercase;color:var(--text-light);font-weight:600;letter-spacing:.3px;white-space:nowrap;}
.data-table td{padding:12px 20px;border-bottom:1px solid var(--border);}
.data-table tr:hover{background:#f8fafc;}
.badge{display:inline-block;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;text-transform:uppercase;}
.badge.success{background:#dcfce7;color:#166534;}
.badge.danger{background:#fee2e2;color:#991b1b;}
.badge.warning{background:#fef3c7;color:#92400e;}
.badge.info{background:#dbeafe;color:#1e40af;}
.actions{display:flex;gap:6px;}
.actions button{padding:6px 12px;border-radius:6px;border:none;font-size:12px;font-weight:600;cursor:pointer;}
.btn-edit{background:#dbeafe;color:#1e40af;}
.btn-delete{background:#fee2e2;color:#991b1b;}
.btn-view{background:#f3f4f6;color:#374151;}
.btn-receipt{background:#dcfce7;color:#166534;}
.empty-state{text-align:center;padding:60px 20px;}
.empty-state .icon{font-size:48px;margin-bottom:16px;}
.empty-state h3{font-size:18px;color:var(--text-light);margin-bottom:8px;}
/* Pagination */
.pagination{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-top:1px solid var(--border);font-size:13px;color:var(--text-light);}
.pagination .pg-btns{display:flex;gap:6px;}
.pagination button{padding:6px 12px;border:1px solid var(--border);border-radius:6px;background:var(--card);font-size:13px;cursor:pointer;}
.pagination button:hover:not(:disabled){background:var(--primary);color:#fff;border-color:var(--primary);}
.pagination button:disabled{opacity:.4;cursor:not-allowed;}
.pagination button.active{background:var(--primary);color:#fff;border-color:var(--primary);}
/* Loading spinner */
.loading-row td{text-align:center;padding:40px;color:var(--text-light);}
.spinner{display:inline-block;width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin .6s linear infinite;margin-right:8px;vertical-align:middle;}
@keyframes spin{to{transform:rotate(360deg)}}
/* Modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:center;justify-content:center;padding:20px;}
.modal-overlay.active{display:flex;}
.modal{background:var(--card);border-radius:16px;width:100%;max-width:560px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2);}
.modal-header{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.modal-header h2{font-size:18px;font-weight:700;}
.modal-header .close{background:none;border:none;font-size:24px;color:var(--text-light);cursor:pointer;}
.modal-body{padding:24px;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-group.full{grid-column:1/-1;}
.form-group label{font-size:12px;font-weight:600;color:var(--text-light);text-transform:uppercase;letter-spacing:.3px;}
.form-group input,.form-group select,.form-group textarea{padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-size:14px;font-family:inherit;outline:none;}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--primary);}
.form-group textarea{min-height:80px;resize:vertical;}
.modal-footer{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:12px;}
.modal-footer button{padding:10px 20px;border-radius:8px;font-weight:600;font-size:14px;cursor:pointer;border:none;}
.btn-cancel{background:var(--bg);color:var(--text);}
.btn-save{background:var(--primary);color:#fff;}
/* Sections */
.section{display:none;}
.section.active{display:block;}
.section-title{font-size:24px;font-weight:700;margin-bottom:20px;}
/* Toast */
.toast{position:fixed;bottom:24px;right:24px;padding:14px 24px;border-radius:10px;color:#fff;font-weight:600;font-size:14px;z-index:300;transform:translateY(100px);opacity:0;transition:.3s;}
.toast.show{transform:translateY(0);opacity:1;}
.toast.success{background:var(--success);}
.toast.error{background:var(--danger);}
/* Prompt */
.prompt-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:250;align-items:center;justify-content:center;padding:20px;}
.prompt-overlay.active{display:flex;}
.prompt-box{background:var(--card);border-radius:16px;padding:32px;max-width:400px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.2);}
.prompt-box h3{font-size:18px;margin-bottom:12px;}
.prompt-box p{color:var(--text-light);margin-bottom:24px;font-size:14px;}
.prompt-buttons{display:flex;gap:12px;justify-content:center;}
.prompt-buttons button{padding:10px 24px;border-radius:8px;font-weight:600;cursor:pointer;border:none;}
.btn-yes{background:var(--primary);color:#fff;}
.btn-no{background:var(--bg);color:var(--text);}
@media(max-width:768px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:translateX(0);}
  .main{margin-left:0;}
  .topbar .mobile-menu{display:block;}
  .stats-grid{grid-template-columns:repeat(2,1fr);}
  .form-grid{grid-template-columns:1fr;}
  .data-table{overflow-x:auto;}
  .data-table table{min-width:600px;}
  .quick-actions{overflow-x:auto;flex-wrap:nowrap;padding-bottom:8px;}
  .modal{max-height:95vh;}
  .table-header{flex-direction:column;align-items:flex-start!important;}
  .table-header .search{width:100%!important;}
}
</style>
</head>
<body>
<div class="app">
  <aside class="sidebar" id="sidebar">
    <div class="logo"><span>🏢</span> PMS</div>
    <nav>
      <a class="active" onclick="showSection('dashboard',event)">📊 Dashboard</a>
      <div class="nav-section">Portfolio</div>
      <a onclick="showSection('landlords',event)">👤 Landlords</a>
      <a onclick="showSection('properties',event)">🏘️ Properties</a>
      <a onclick="showSection('units',event)">🚪 Units</a>
      <div class="nav-section">Leasing</div>
      <a onclick="showSection('tenants',event)">👥 Tenants</a>
      <a onclick="showSection('rent',event)">💰 Rent Collection</a>
      <a onclick="showSection('arrears',event)">⚠️ Arrears</a>
      <div class="nav-section">Finance</div>
      <a onclick="showSection('expenses',event)">📑 Expenses</a>
      <a onclick="showSection('invoices',event)">📄 Invoices</a>
      <a onclick="showSection('receipts',event)">🧾 Receipts</a>
      <div class="nav-section" id="navAdminLabel">Admin</div>
      <a onclick="showSection('users',event)" id="navUsers">🔐 Users</a>
      <a onclick="showSection('settings',event)" id="navSettings">⚙️ Settings</a>
    </nav>
    <div class="user">
      <div class="name" id="userName">Loading...</div>
      <div class="role" id="userRole">...</div>
      <button class="logout" onclick="logout()">🚪 Sign Out</button>
    </div>
  </aside>

  <div class="main">
    <div class="topbar">
      <button class="mobile-menu" onclick="toggleSidebar()">☰</button>
      <h1 id="pageTitle">Dashboard</h1>
      <div class="date" id="dashDate"></div>
    </div>
    <div class="content">

      <!-- Dashboard -->
      <div class="section active" id="sec-dashboard">
        <div class="stats-grid">
          <div class="stat-card"><div class="label">Landlords</div><div class="value" id="statLandlords">—</div></div>
          <div class="stat-card"><div class="label">Properties</div><div class="value" id="statProperties">—</div></div>
          <div class="stat-card"><div class="label">Units</div><div class="value" id="statUnits">—</div></div>
          <div class="stat-card"><div class="label">Tenants</div><div class="value" id="statTenants">—</div></div>
          <div class="stat-card"><div class="label">Occupied</div><div class="value" id="statOccupied">—</div></div>
          <div class="stat-card"><div class="label">Vacant</div><div class="value" id="statVacant">—</div></div>
          <div class="stat-card"><div class="label">Total Rent</div><div class="value" id="statRent">—</div></div>
          <div class="stat-card"><div class="label">Expenses</div><div class="value" id="statExpenses">—</div></div>
        </div>
        <div class="quick-actions">
          <button onclick="openModal('landlord')">+ Add Landlord</button>
          <button onclick="openModal('property')">+ Add Property</button>
          <button onclick="openModal('unit')">+ Add Unit</button>
          <button onclick="openModal('tenant')">+ Add Tenant</button>
          <button class="secondary" onclick="openModal('rent')">+ Record Rent</button>
          <button class="secondary" onclick="openModal('expense')">+ Add Expense</button>
          <button class="secondary" onclick="openModal('invoice')">+ Create Invoice</button>
        </div>
      </div>

      <!-- Landlords -->
      <div class="section" id="sec-landlords">
        <div class="section-title">Landlords</div>
        <div class="quick-actions"><button onclick="openModal('landlord')">+ Add Landlord</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Landlords</h3><input class="search" placeholder="Search..." oninput="filterTable('landlordsTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Email</th><th>Commission</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="landlordsTable"><tr class="loading-row"><td colspan="7"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- Properties -->
      <div class="section" id="sec-properties">
        <div class="section-title">Properties</div>
        <div class="quick-actions"><button onclick="openModal('property')">+ Add Property</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Properties</h3><input class="search" placeholder="Search..." oninput="filterTable('propertiesTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Landlord</th><th>Address</th><th>Type</th><th>Units</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="propertiesTable"><tr class="loading-row"><td colspan="8"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- Units -->
      <div class="section" id="sec-units">
        <div class="section-title">Units</div>
        <div class="quick-actions"><button onclick="openModal('unit')">+ Add Unit</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Units</h3><input class="search" placeholder="Search..." oninput="filterTable('unitsTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Property</th><th>Unit No.</th><th>Type</th><th>Rent (UGX)</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="unitsTable"><tr class="loading-row"><td colspan="7"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- Tenants -->
      <div class="section" id="sec-tenants">
        <div class="section-title">Tenants</div>
        <div class="quick-actions"><button onclick="openModal('tenant')">+ Add Tenant</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Tenants</h3><input class="search" placeholder="Search..." oninput="filterTable('tenantsTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Unit</th><th>Rent (UGX)</th><th>Lease End</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="tenantsTable"><tr class="loading-row"><td colspan="8"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- Rent -->
      <div class="section" id="sec-rent">
        <div class="section-title">Rent Collection</div>
        <div class="quick-actions"><button onclick="openModal('rent')">+ Record Payment</button></div>
        <div class="data-table">
          <div class="table-header"><h3>Payment History</h3><input class="search" placeholder="Search..." oninput="filterTable('rentTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Tenant</th><th>Unit</th><th>Amount (UGX)</th><th>Period</th><th>Method</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody id="rentTable"><tr class="loading-row"><td colspan="8"><span class="spinner"></span>Loading…</td></tr></tbody></table>
          <div class="pagination" id="rentPagination" style="display:none"></div>
        </div>
      </div>

      <!-- Arrears -->
      <div class="section" id="sec-arrears">
        <div class="section-title">Arrears</div>
        <div class="data-table">
          <div class="table-header"><h3>Outstanding Rent</h3></div>
          <table><thead><tr><th>Tenant</th><th>Unit</th><th>Monthly Rent</th><th>Months Due</th><th>Total Due (UGX)</th><th>Actions</th></tr></thead>
          <tbody id="arrearsTable"><tr class="loading-row"><td colspan="6"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- Expenses -->
      <div class="section" id="sec-expenses">
        <div class="section-title">Expenses</div>
        <div class="quick-actions"><button onclick="openModal('expense')">+ Add Expense</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Expenses</h3><input class="search" placeholder="Search..." oninput="filterTable('expensesTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Property</th><th>Category</th><th>Description</th><th>Amount (UGX)</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody id="expensesTable"><tr class="loading-row"><td colspan="7"><span class="spinner"></span>Loading…</td></tr></tbody></table>
          <div class="pagination" id="expensesPagination" style="display:none"></div>
        </div>
      </div>

      <!-- Invoices -->
      <div class="section" id="sec-invoices">
        <div class="section-title">Invoices</div>
        <div class="quick-actions"><button onclick="openModal('invoice')">+ Create Invoice</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Invoices</h3><input class="search" placeholder="Search..." oninput="filterTable('invoicesTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Type</th><th>Entity</th><th>Description</th><th>Amount (UGX)</th><th>Period</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="invoicesTable"><tr class="loading-row"><td colspan="8"><span class="spinner"></span>Loading…</td></tr></tbody></table>
          <div class="pagination" id="invoicesPagination" style="display:none"></div>
        </div>
      </div>

      <!-- Receipts -->
      <div class="section" id="sec-receipts">
        <div class="section-title">Receipts</div>
        <div class="data-table">
          <div class="table-header"><h3>All Receipts</h3><input class="search" placeholder="Search..." oninput="filterTable('receiptsTable',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Tenant</th><th>Unit</th><th>Amount (UGX)</th><th>Period</th><th>Method</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody id="receiptsTable"><tr class="loading-row"><td colspan="8"><span class="spinner"></span>Loading…</td></tr></tbody></table>
          <div class="pagination" id="receiptsPagination" style="display:none"></div>
        </div>
      </div>

      <!-- Users -->
      <div class="section" id="sec-users">
        <div class="section-title">Users</div>
        <div class="data-table">
          <div class="table-header"><h3>All Users</h3></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Username</th><th>Email</th><th>Role</th><th>Status</th></tr></thead>
          <tbody id="usersTable"><tr class="loading-row"><td colspan="6"><span class="spinner"></span>Loading…</td></tr></tbody></table>
        </div>
      </div>

      <!-- Settings -->
      <div class="section" id="sec-settings">
        <div class="section-title">Settings</div>
        <div class="data-table" style="max-width:600px;">
          <div class="table-header"><h3>System Settings</h3></div>
          <div id="settingsContent" style="padding:20px;">Loading...</div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="modal-header"><h2 id="modalTitle">Add New</h2><button class="close" onclick="closeModal()">×</button></div>
    <div class="modal-body" id="modalBody"></div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn-save" id="modalSave" onclick="saveForm()">Save</button>
    </div>
  </div>
</div>

<!-- Prompt -->
<div class="prompt-overlay" id="promptOverlay" onclick="if(event.target===this)closePrompt()">
  <div class="prompt-box">
    <h3 id="promptTitle">Confirm</h3>
    <p id="promptMessage"></p>
    <div class="prompt-buttons">
      <button class="btn-yes" id="promptYes">Yes</button>
      <button class="btn-no" onclick="closePrompt()">No</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const USER = <%- JSON.stringify(user) %>;

// ── State ────────────────────────────────────────────────────────────────────
let landlords=[], properties=[], units=[], tenants=[], rentData=[], settings={};
let currentForm='', editingId=null;
// Pagination state for paginated tables
const pgState = {
  rent:     { page:1, pages:1 },
  expenses: { page:1, pages:1 },
  invoices: { page:1, pages:1 },
  receipts: { page:1, pages:1 }
};

// ── Field Accessors (handles any column name variation) ───────────────────────
const isActive = x => (x.Status||x.status||'Active').trim().toLowerCase() === 'active';
const isVacant = u => (u.Status||u.status||'Vacant').trim().toLowerCase() === 'vacant';

const ll = {
  id:   l=>l.ID||l['Landlord ID']||'', name: l=>l.Name||'',
  phone:l=>l.Phone||'',               email:l=>l.Email||'',
  comm: l=>l['Commission Rate']||l.Commission||'10',
  status:l=>l.Status||'Active',
};
const pr = {
  id:   p=>p.ID||p['Property ID']||'', name:p=>p.Name||'',
  llid: p=>p['Landlord ID']||'',       llname:p=>p['Landlord Name']||'',
  addr: p=>p.Address||'',              type:p=>p.Type||'Residential',
  units:p=>p['Total Units']||'0',      status:p=>p.Status||'Active',
};
const un = {
  id:   u=>u.ID||u['Unit ID']||'', prop:u=>u['Property ID']||'',
  pname:u=>u['Property Name']||'', num: u=>u['Unit Number']||'',
  type: u=>u.Type||'Studio',       rent:u=>u.Rent||u['Rent']||'0',
  desc: u=>u.Description||'',      status:u=>u.Status||'Vacant',
};
const tn = {
  id:     t=>t.ID||t['Tenant ID']||'', name:  t=>t.Name||'',
  phone:  t=>t.Phone||'',              email: t=>t.Email||'',
