function loadArrears() {
  const tbody = document.getElementById('arrearsTable');
  const activeTenants = (tenants || []).filter(t=>t.Status==='Active');
  const arrears = [];
  const now = new Date();
  activeTenants.forEach(t=>{
    const unit = (units || []).find(u=>u.ID===t['Unit ID']);
    const rentAmt = parseFloat(t['Rent Amount'])||0;
    if(!rentAmt) return;
    const leaseStart = t['Lease Start'] ? new Date(t['Lease Start']) : null;
    if(!leaseStart) return;
    const tenantPayments = (rentData || []).filter(r=>r['Tenant ID']===t.ID);
    const paidMonths = new Set(tenantPayments.map(r=>`${r.Year}-${r.Month}`));
    let monthsDue = 0;
    let checkDate = new Date(leaseStart);
    checkDate.setMonth(checkDate.getMonth()+1);
    while(checkDate <= now) {
      const ym = `${checkDate.getFullYear()}-${String(checkDate.getMonth()+1).padStart(2,'0')}`;
      if(!paidMonths.has(ym)) monthsDue++;
      checkDate.setMonth(checkDate.getMonth()+1);
    }
    if(monthsDue > 0) arrears.push({ tenant:t, unit:unit, rent:rentAmt, months:monthsDue, total:rentAmt*monthsDue });
  });
  if(!arrears.length){ tbody.innerHTML='<tr><td colspan="6" class="empty-state"><div class="icon">✅</div><h3>No arrears</h3><p>All tenants are up to date</p></td></tr>'; return; }
  tbody.innerHTML = arrears.map(a=>`<tr><td>${a.tenant.Name}</td><td>${a.unit?a.unit['Unit Number']:'N/A'}</td><td>${a.rent}</td><td>${a.months}</td><td style="color:var(--danger);font-weight:700">${a.total.toLocaleString()}</td><td class="actions"><button class="btn-edit" onclick="openModal('rent','${a.tenant.ID||''}')">Record Payment</button></td></tr>`).join('');
}

