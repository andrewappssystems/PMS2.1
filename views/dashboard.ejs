function closePrompt() {
  document.getElementById('promptOverlay').classList.remove('active');
}

async function saveForm() {
  const btn = document.getElementById('modalSave');
  btn.textContent = 'Saving...'; btn.disabled = true;
  try {
    let payload={}, endpoint='';
    switch(currentForm) {
      case 'landlord': endpoint='/api/landlords'; payload={name:gv('f_name'),phone:gv('f_phone'),email:gv('f_email'),address:gv('f_address'),bankName:gv('f_bank'),bankAccount:gv('f_account'),commissionRate:gv('f_commission')}; break;
      case 'property': endpoint='/api/properties'; payload={name:gv('f_name'),landlordId:gv('f_landlord'),address:gv('f_address'),type:gv('f_type')}; break;
      case 'unit': endpoint='/api/units'; payload={propertyId:gv('f_property'),unitNumber:gv('f_unitno'),type:gv('f_type'),rent:gv('f_rent'),description:gv('f_desc')}; break;
      case 'tenant': endpoint='/api/tenants'; payload={name:gv('f_name'),phone:gv('f_phone'),email:gv('f_email'),idNumber:gv('f_idno'),unitId:gv('f_unit'),leaseStart:gv('f_start'),leaseEnd:gv('f_end'),rentAmount:gv('f_rent'),deposit:gv('f_deposit')}; break;
      case 'rent': endpoint='/api/rent'; payload={tenantId:gv('f_tenant'),unitId:gv('f_unit'),amount:gv('f_amount'),month:gv('f_month'),year:gv('f_year'),paymentMethod:gv('f_method'),reference:gv('f_ref')}; break;
      case 'expense': endpoint='/api/expenses'; payload={propertyId:gv('f_property'),category:gv('f_category'),description:gv('f_desc'),amount:gv('f_amount'),date:gv('f_date')}; break;
      case 'invoice': endpoint='/api/invoices'; payload={type:gv('f_invType'),entityId:gv('f_entity'),entityName:getEntityName(gv('f_invType'),gv('f_entity')),description:gv('f_desc'),amount:gv('f_amount'),month:gv('f_month'),year:gv('f_year')}; break;
    }

    if(currentForm==='property' && !payload.landlordId) { showToast('Please select a landlord','error'); btn.textContent='Save'; btn.disabled=false; return; }
    if(currentForm==='unit' && !payload.propertyId) { showToast('Please select a property','error'); btn.textContent='Save'; btn.disabled=false; return; }
    if(currentForm==='tenant' && !payload.unitId) { showToast('Please select a unit','error'); btn.textContent='Save'; btn.disabled=false; return; }
    if(currentForm==='rent' && !payload.tenantId) { showToast('Please select a tenant','error'); btn.textContent='Save'; btn.disabled=false; return; }
    if(currentForm==='invoice' && (!payload.type || !payload.entityId)) { showToast('Please select invoice type and entity','error'); btn.textContent='Save'; btn.disabled=false; return; }

    const res = await fetch(endpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const data = await res.json();
    if(data.success){
      showToast('Saved successfully!','success');
      closeModal();
      await loadAllData();
      if(currentForm==='property') {
        showPrompt('Add Units?', `Do you want to add units to "${payload.name}" now?`, function() {
          openModal('unit');
          setTimeout(()=>{ const propSel=document.getElementById('f_property'); if(propSel) propSel.value=data.id; }, 100);
        });
      }
      if(currentForm==='rent') {
        const t=tenants.find(x=>x.ID===payload.tenantId);
        const u=units.find(x=>x.ID===payload.unitId);
        const rcpPayload={rentId:data.id,tenantName:t?t.Name:'',unitNumber:u?u['Unit Number']:'',amount:payload.amount,month:payload.month,year:payload.year,paymentMethod:payload.paymentMethod};
        const rcpRes=await fetch('/api/receipts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(rcpPayload)});
        const rcpData=await rcpRes.json();
        if(rcpData.success) {
          showToast('Receipt generated! 🧾','success');
          await loadAllData();
          showPrompt('View Receipt?', 'Receipt generated. View it now?', function() { viewReceipt(rcpData.id); });
        }
      }
    } else {
      showToast(data.error||'Failed to save','error');
    }
  } catch(e) { showToast('Error: '+e.message,'error'); }
  btn.textContent = 'Save'; btn.disabled = false;
}

function getEntityName(type, id) {
  if(type==='landlord') { const l=landlords.find(x=>x.ID===id); return l?l.Name:''; }
  else { const t=tenants.find(x=>x.ID===id); return t?t.Name:''; }
}

function gv(id){ const el=document.getElementById(id); return el?el.value:''; }

