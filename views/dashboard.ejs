async function deleteLandlord(id) {
  if(!confirm('Delete this landlord?')) return;
  await fetch('/api/landlords/'+id,{method:'DELETE'});
  showToast('Deleted','success'); loadAllData();
}

// ── Invoice / Receipt Actions ─────────────────────────────────────────
function viewInvoice(id){ window.open('/api/invoices/'+id+'/pdf','_blank'); }
function viewReceipt(id){ window.open('/api/receipts/'+id+'/pdf','_blank'); }

async function payInvoice(id) {
  await fetch('/api/invoices/'+id+'/pay',{method:'PUT'});
  showToast('Invoice marked as paid','success');
  loadAllData();
}

async function quickReceipt(rentId) {
  const r=rentData.find(x=>x.ID===rentId); if(!r){ showToast('Rent record not found','error'); return; }
  const t=tenants.find(x=>x.ID===r['Tenant ID'])||{};
  const u=units.find(x=>x.ID===r['Unit ID'])||{};
  const payload={rentId,tenantName:t.Name||'',unitNumber:u['Unit Number']||'',amount:r.Amount,month:r.Month,year:r.Year,paymentMethod:r['Payment Method']||'Cash'};
  const res=await fetch('/api/receipts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
  const data=await res.json();
  if(data.success){ showToast('Receipt generated!','success'); loadAllData(); viewReceipt(data.id); }
}

// ── Table Filter ─────────────────────────────────────────────────────
function filterTable(tbodyId, query) {
  const tbody=document.getElementById(tbodyId);
  const rows=tbody.querySelectorAll('tr');
  const q=query.toLowerCase();
  rows.forEach(row=>{ if(row.querySelector('.empty-state')) return; row.style.display=row.textContent.toLowerCase().includes(q)?'':'none'; });
}

// ── Toast ─────────────────────────────────────────────────────────────
function showToast(msg, type='success') {
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast '+type+' show';
  setTimeout(()=>t.classList.remove('show'),3000);
}
