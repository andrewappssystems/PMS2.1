<div class="toast" id="toast"></div>

<script>
const USER = <%- JSON.stringify(user) %>;

// ── State ─────────────────────────────────────────────────────────────────────
let landlords=[], properties=[], units=[], tenants=[], rentData=[], allUsers=[], settings={};
let currentForm='', editingId=null;
let pendingLogoBase64 = null;
const pgState = { rent:{page:1,pages:1}, expenses:{page:1,pages:1}, invoices:{page:1,pages:1}, receipts:{page:1,pages:1} };

// ── Accessors ─────────────────────────────────────────────────────────────────
const isActive = x => (x.Status||x.status||'Active').toLowerCase()==='active';
const isVacant = u => (u.Status||u.status||'Vacant').toLowerCase()==='vacant';
const ll={id:l=>l.ID||'',name:l=>l.Name||'',phone:l=>l.Phone||'',email:l=>l.Email||'',comm:l=>l['Commission Rate']||'10',status:l=>l.Status||'Active',addr:l=>l.Address||'',bank:l=>l['Bank Name']||'',acct:l=>l['Bank Account']||''};
const pr={id:p=>p.ID||'',name:p=>p.Name||'',llid:p=>p['Landlord ID']||'',llname:p=>p['Landlord Name']||'',addr:p=>p.Address||'',type:p=>p.Type||'Residential',units:p=>p['Total Units']||'0',status:p=>p.Status||'Active'};
const un={id:u=>u.ID||'',prop:u=>u['Property ID']||'',pname:u=>u['Property Name']||'',num:u=>u['Unit Number']||'',type:u=>u.Type||'Studio',rent:u=>u.Rent||'0',desc:u=>u.Description||'',status:u=>u.Status||'Vacant'};
const tn={id:t=>t.ID||'',name:t=>t.Name||'',phone:t=>t.Phone||'',email:t=>t.Email||'',idno:t=>t['ID Number']||'',unit:t=>t['Unit ID']||'',unum:t=>t['Unit Number']||'',start:t=>t['Lease Start']||'',end:t=>t['Lease End']||'',rent:t=>t['Rent Amount']||'0',deposit:t=>t.Deposit||'0',status:t=>t.Status||'Active'};
const rn={id:r=>r.ID||'',tenant:r=>r['Tenant ID']||'',tname:r=>r['Tenant Name']||'',unit:r=>r['Unit ID']||'',unum:r=>r['Unit Number']||'',amt:r=>r.Amount||'0',month:r=>r.Month||'',year:r=>r.Year||'',method:r=>r['Payment Method']||'Cash',date:r=>r.Date||''};
const ex={id:e=>e.ID||'',prop:e=>e['Property ID']||'',pname:e=>e['Property Name']||'',cat:e=>e.Category||'',desc:e=>e.Description||'',amt:e=>e.Amount||'0',date:e=>e.Date||''};
const inv={id:i=>i.ID||'',type:i=>i.Type||'',eid:i=>i.EntityId||'',ename:i=>i.EntityName||'',desc:i=>i.Description||'',amt:i=>i.Amount||'0',month:i=>i.Month||'',year:i=>i.Year||'',status:i=>i.Status||'Unpaid'};
const rc={id:r=>r.ID||'',tenant:r=>r.TenantName||'',unit:r=>r.UnitNumber||'',amt:r=>r.Amount||'0',month:r=>r.Month||'',year:r=>r.Year||'',method:r=>r.PaymentMethod||'Cash',date:r=>r.Date||''};

// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', ()=>{
  document.getElementById('userName').textContent = USER.name||USER.username;
  document.getElementById('userRole').textContent = USER.role;
  document.getElementById('dashDate').textContent = new Date().toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  if(USER.role!=='Admin'){
    ['navAdminLabel','navUsers','navSettings'].forEach(id=>{ const el=document.getElementById(id); if(el) el.style.display='none'; });
  } else {
    const ua=document.getElementById('usersActions'); if(ua) ua.style.display='flex';
    const sb=document.getElementById('saveSettingsBtn'); if(sb) sb.style.display='block';
    const lr=document.getElementById('logoRow'); if(lr) lr.style.display='flex';
  }
  loadAllData();
});

function logout(){ window.location.href='/logout'; }
function toggleSidebar(){ document.getElementById('sidebar').classList.toggle('open'); }
function showSection(id,e){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.sidebar nav a').forEach(a=>a.classList.remove('active'));
  document.getElementById('sec-'+id).classList.add('active');
  if(e&&e.target) e.target.classList.add('active');
  document.getElementById('pageTitle').textContent=id.charAt(0).toUpperCase()+id.slice(1);
  document.getElementById('sidebar').classList.remove('open');
  if(id==='arrears') renderArrears();
}

// ── Data Loading ──────────────────────────────────────────────────────────────
async function loadAllData(){
  try {
    const s=await fetch('/api/stats').then(r=>r.json());
    document.getElementById('statLandlords').textContent=s.landlords||0;
    document.getElementById('statProperties').textContent=s.properties||0;
    document.getElementById('statUnits').textContent=s.units||0;
    document.getElementById('statTenants').textContent=s.tenants||0;
    document.getElementById('statOccupied').textContent=s.occupied||0;
    document.getElementById('statVacant').textContent=s.vacant||0;
    document.getElementById('statRent').textContent='UGX '+Number(s.totalRent||0).toLocaleString();
    document.getElementById('statExpenses').textContent='UGX '+Number(s.totalExpenses||0).toLocaleString();
  } catch(e){ console.error('Stats',e); }

  const load = async (url,fb=[])=>{ try{ return await fetch(url).then(r=>r.json()); }catch(e){ return fb; } };
  landlords  = await load('/api/landlords');  renderLandlords();
  properties = await load('/api/properties'); renderProperties();
  units      = await load('/api/units');      renderUnits();
  tenants    = await load('/api/tenants');    renderTenants();
  settings   = await load('/api/settings',{}); renderSettings(); applyBranding();
  if(USER.role==='Admin'){ allUsers=await load('/api/users',[]); renderUsers(); }
  await loadPage('rent',1);
  await loadPage('expenses',1);
  await loadPage('invoices',1);
  await loadPage('receipts',1);
  // After all data loaded, compute arrears for dashboard
  computeDashboardArrears();
}

// ── Arrears computation ───────────────────────────────────────────────────────
function computeArrearsForAll(){
  const now=new Date(); const arr=[];
  tenants.filter(t=>isActive(t)).forEach(t=>{
    const u=units.find(x=>un.id(x)===tn.unit(t));
    const rentAmt=parseFloat(tn.rent(t))||0; if(!rentAmt) return;
    const leaseStart=tn.start(t)?new Date(tn.start(t)):null; if(!leaseStart) return;
    const paid=new Set(rentData.filter(r=>rn.tenant(r)===tn.id(t)).map(r=>`${rn.year(r)}-${String(rn.month(r)).padStart(2,'0')}`));
    let due=0; const check=new Date(leaseStart); check.setMonth(check.getMonth()+1);
    while(check<=now){ const ym=`${check.getFullYear()}-${String(check.getMonth()+1).padStart(2,'0')}`; if(!paid.has(ym)) due++; check.setMonth(check.getMonth()+1); }
    if(due>0) arr.push({t,u,rent:rentAmt,months:due,total:rentAmt*due});
  });
  return arr.sort((a,b)=>b.total-a.total);
}

function computeDashboardArrears(){
  const arr=computeArrearsForAll();
  const totalArrears=arr.reduce((s,a)=>s+a.total,0);
  document.getElementById('statArrears').textContent='UGX '+totalArrears.toLocaleString();
  document.getElementById('statArrearsCount').textContent=arr.length;
  // Critical = 2+ months overdue
  const critical=arr.filter(a=>a.months>=2);
  const widget=document.getElementById('criticalArrearsWidget');
  if(!critical.length){ widget.style.display='none'; return; }
  widget.style.display='block';
  document.getElementById('criticalArrearsSubtitle').textContent=`— ${critical.length} tenant${critical.length>1?'s':''} with 2+ months overdue`;
  const top5=critical.slice(0,5);
  document.getElementById('criticalArrearsList').innerHTML=top5.map(a=>`
    <div class="arrears-item">
      <div>
        <div class="ai-info">${tn.name(a.t)}</div>
        <div class="ai-sub">Unit: ${a.u?un.num(a.u):'N/A'} &nbsp;|&nbsp; ${a.months} months overdue</div>
      </div>
      <div class="ai-amt">UGX ${a.total.toLocaleString()}</div>
    </div>`).join('');
}

function renderArrears(){
  const tb=document.getElementById('arrearsTable');
  const arr=computeArrearsForAll();
  if(!arr.length){ tb.innerHTML=empty(7,'✅','All tenants are up to date'); return; }
  tb.innerHTML=arr.map(a=>{
    const level=a.months>=3?'danger':a.months>=2?'warning':'info';
    const label=a.months>=3?'Critical':a.months>=2?'High':'Overdue';
    return `<tr>
      <td><strong>${tn.name(a.t)}</strong></td>
      <td>${a.u?un.num(a.u):'N/A'}</td>
      <td>${Number(a.rent).toLocaleString()}</td>
      <td>${a.months}</td>
      <td style="font-weight:700;color:var(--danger)">UGX ${a.total.toLocaleString()}</td>
      <td><span class="badge ${level}">${label}</span></td>
      <td class="actions"><button class="btn-edit" onclick="openModal('rent',null,'${tn.id(a.t)}')">Record Payment</button></td>
    </tr>`;
  }).join('');
}

// ── Paginated loader ──────────────────────────────────────────────────────────
async function loadPage(type,page){
  const urlMap={rent:'/api/rent',expenses:'/api/expenses',invoices:'/api/invoices',receipts:'/api/receipts'};
  try {
    const res=await fetch(`${urlMap[type]}?page=${page}&limit=50`).then(r=>r.json());
    const rows=Array.isArray(res)?res:(res.data||[]);
    const pages=Array.isArray(res)?1:(res.pages||1);
    pgState[type]={page:Array.isArray(res)?1:(res.page||1),pages};
    if(type==='rent'){ rentData=rows; renderRent(); renderPg('rent','rentPagination'); computeDashboardArrears(); }
    if(type==='expenses'){ renderExpensesData(rows); renderPg('expenses','expensesPagination'); }
    if(type==='invoices'){ renderInvoicesData(rows); renderPg('invoices','invoicesPagination'); }
    if(type==='receipts'){ renderReceiptsData(rows); renderPg('receipts','receiptsPagination'); }
  } catch(e){ console.error(`loadPage ${type}`,e); }
}

function renderPg(type,cid){
  const {page,pages}=pgState[type];
  const el=document.getElementById(cid); if(!el) return;
  if(pages<=1){ el.style.display='none'; return; }
  el.style.display='flex';
  const s=Math.max(1,page-2),e=Math.min(pages,page+2);
  let btns='';
  if(s>1) btns+=`<button onclick="loadPage('${type}',1)">1</button>`;
  if(s>2) btns+=`<span style="padding:4px">…</span>`;
  for(let i=s;i<=e;i++) btns+=`<button class="${i===page?'active':''}" onclick="loadPage('${type}',${i})">${i}</button>`;
  if(e<pages-1) btns+=`<span style="padding:4px">…</span>`;
  if(e<pages) btns+=`<button onclick="loadPage('${type}',${pages})">${pages}</button>`;
  el.innerHTML=`<span>Page ${page} of ${pages}</span><div class="pg-btns"><button onclick="loadPage('${type}',${page-1})" ${page<=1?'disabled':''}>← Prev</button>${btns}<button onclick="loadPage('${type}',${page+1})" ${page>=pages?'disabled':''}>Next →</button></div>`;
}

// ── Render functions ──────────────────────────────────────────────────────────
const empty=(n,icon,msg)=>`<tr><td colspan="${n}"><div class="empty-state"><div class="icon">${icon}</div><h3>${msg}</h3></div></td></tr>`;

function renderLandlords(){
  const tb=document.getElementById('landlordsTable');
  if(!landlords.length){ tb.innerHTML=empty(7,'📋','No landlords yet'); return; }
  tb.innerHTML=landlords.map(l=>`<tr><td>${ll.id(l)}</td><td><strong>${ll.name(l)}</strong></td><td>${ll.phone(l)}</td><td>${ll.email(l)}</td><td>${ll.comm(l)}%</td><td><span class="badge ${isActive(l)?'success':'danger'}">${ll.status(l)}</span></td><td class="actions"><button class="btn-edit" onclick="editLandlord('${ll.id(l)}')">Edit</button><button class="btn-delete" onclick="deleteLandlord('${ll.id(l)}')">Delete</button></td></tr>`).join('');
}
function renderProperties(){
  const tb=document.getElementById('propertiesTable');
  if(!properties.length){ tb.innerHTML=empty(8,'🏘️','No properties yet'); return; }
  tb.innerHTML=properties.map(p=>`<tr><td>${pr.id(p)}</td><td><strong>${pr.name(p)}</strong></td><td>${pr.llname(p)||pr.llid(p)}</td><td>${pr.addr(p)}</td><td>${pr.type(p)}</td><td>${pr.units(p)}</td><td><span class="badge ${isActive(p)?'success':'danger'}">${pr.status(p)}</span></td><td class="actions"><button class="btn-edit" onclick="editProperty('${pr.id(p)}')">Edit</button></td></tr>`).join('');
}
function renderUnits(){
  const tb=document.getElementById('unitsTable');
  if(!units.length){ tb.innerHTML=empty(7,'🚪','No units yet'); return; }
  tb.innerHTML=units.map(u=>`<tr><td>${un.id(u)}</td><td>${un.pname(u)||un.prop(u)}</td><td><strong>${un.num(u)}</strong></td><td>${un.type(u)}</td><td>${Number(un.rent(u)||0).toLocaleString()}</td><td><span class="badge ${isVacant(u)?'warning':'success'}">${un.status(u)}</span></td><td class="actions"><button class="btn-edit" onclick="editUnit('${un.id(u)}')">Edit</button></td></tr>`).join('');
}
function renderTenants(){
  const tb=document.getElementById('tenantsTable');
  if(!tenants.length){ tb.innerHTML=empty(8,'👥','No tenants yet'); return; }
  tb.innerHTML=tenants.map(t=>`<tr><td>${tn.id(t)}</td><td><strong>${tn.name(t)}</strong></td><td>${tn.phone(t)}</td><td>${tn.unum(t)||tn.unit(t)}</td><td>${Number(tn.rent(t)||0).toLocaleString()}</td><td>${tn.end(t)||'—'}</td><td><span class="badge ${isActive(t)?'success':'danger'}">${tn.status(t)}</span></td><td class="actions"><button class="btn-edit" onclick="editTenant('${tn.id(t)}')">Edit</button></td></tr>`).join('');
}
function renderRent(){
  const tb=document.getElementById('rentTable');
  if(!rentData.length){ tb.innerHTML=empty(8,'💰','No payments recorded'); return; }
  tb.innerHTML=rentData.map(r=>`<tr><td>${rn.id(r)}</td><td>${rn.tname(r)||rn.tenant(r)}</td><td>${rn.unum(r)||rn.unit(r)}</td><td>${Number(rn.amt(r)||0).toLocaleString()}</td><td>${rn.month(r)} ${rn.year(r)}</td><td>${rn.method(r)}</td><td>${rn.date(r)}</td><td class="actions"><button class="btn-receipt" onclick="quickReceiptFromRent('${rn.id(r)}')">🧾 Receipt</button></td></tr>`).join('');
}
function renderExpensesData(rows){
  const tb=document.getElementById('expensesTable');
  if(!rows.length){ tb.innerHTML=empty(7,'📑','No expenses recorded'); return; }
  tb.innerHTML=rows.map(e=>`<tr><td>${ex.id(e)}</td><td>${ex.pname(e)||'—'}</td><td>${ex.cat(e)}</td><td>${ex.desc(e)}</td><td>${Number(ex.amt(e)||0).toLocaleString()}</td><td>${ex.date(e)}</td><td class="actions"><button class="btn-edit" onclick="editExpense('${ex.id(e)}')">Edit</button></td></tr>`).join('');
}
function renderInvoicesData(rows){
  const tb=document.getElementById('invoicesTable');
  if(!rows.length){ tb.innerHTML=empty(8,'📄','No invoices yet'); return; }
  tb.innerHTML=rows.map(i=>`<tr><td>${inv.id(i)}</td><td>${inv.type(i)}</td><td>${inv.ename(i)}</td><td>${inv.desc(i)}</td><td>${Number(inv.amt(i)||0).toLocaleString()}</td><td>${inv.month(i)} ${inv.year(i)}</td><td><span class="badge ${inv.status(i).toLowerCase()==='paid'?'success':'danger'}">${inv.status(i)}</span></td><td class="actions"><button class="btn-view" onclick="viewInvoice('${inv.id(i)}')">View</button>${inv.status(i)!=='Paid'?`<button class="btn-edit" onclick="payInvoice('${inv.id(i)}')">Pay</button>`:''}</td></tr>`).join('');
}
function renderReceiptsData(rows){
  const tb=document.getElementById('receiptsTable');
  if(!rows.length){ tb.innerHTML=empty(8,'🧾','No receipts yet'); return; }
  tb.innerHTML=rows.map(r=>`<tr><td>${rc.id(r)}</td><td>${rc.tenant(r)}</td><td>${rc.unit(r)}</td><td>${Number(rc.amt(r)||0).toLocaleString()}</td><td>${rc.month(r)} ${rc.year(r)}</td><td>${rc.method(r)}</td><td>${rc.date(r)}</td><td class="actions"><button class="btn-view" onclick="viewReceipt('${rc.id(r)}')">View</button></td></tr>`).join('');
}
function renderUsers(){
  const tb=document.getElementById('usersTable');
  if(!allUsers.length){ tb.innerHTML=empty(7,'🔐','No users found'); return; }
  tb.innerHTML=allUsers.map(u=>`<tr><td>${u.ID||''}</td><td>${u.Name||''}</td><td>${u.Username||''}</td><td>${u.Email||''}</td><td><span class="badge info">${u.Role||'User'}</span></td><td><span class="badge ${(u.Status||'').toLowerCase()==='active'?'success':'danger'}">${u.Status||'Active'}</span></td><td class="actions">${USER.role==='Admin'?`<button class="btn-edit" onclick="editUser('${u.ID||''}')">Edit</button><button class="btn-pwd" onclick="setPassword('${u.ID||''}','${u.Name||u.Username||''}')">Set Password</button><button class="btn-delete" onclick="deactivateUser('${u.ID||''}')">Deactivate</button>`:'—'}</td></tr>`).join('');
}

// ── Settings render & save ────────────────────────────────────────────────────
const SETTING_LABELS = {
  company_name:'Company Name', company_address:'Address',
  company_phone:'Phone', company_email:'Email',
  currency:'Currency', vat_rate:'VAT Rate (%)'
};
function renderSettings(){
  const form=document.getElementById('settingsForm');
  // Apply logo if exists
  if(settings.company_logo){
    document.getElementById('logoPreviewWrap').innerHTML=`<img class="logo-preview" src="${settings.company_logo}" alt="Logo">`;
  }
  if(USER.role!=='Admin'){
    // Read-only view for non-admins
    const entries=Object.entries(settings).filter(([k])=>k!=='company_logo');
    if(!entries.length){ form.innerHTML='<div style="padding:20px;color:var(--text-light)">No settings configured</div>'; return; }
    form.innerHTML=entries.map(([k,v])=>`<div class="settings-row"><label>${SETTING_LABELS[k]||k}</label><span>${v}</span></div>`).join('');
    return;
  }
  // Editable form for admin
  const keys=['company_name','company_address','company_phone','company_email','currency','vat_rate'];
  form.innerHTML=keys.map(k=>`
    <div class="settings-row">
      <label for="setting_${k}">${SETTING_LABELS[k]||k}</label>
      <input id="setting_${k}" value="${(settings[k]||'').replace(/"/g,'&quot;')}" placeholder="${SETTING_LABELS[k]||k}">
    </div>`).join('');
}
function applyBranding(){
  // Apply company name to sidebar
  const name=settings.company_name||'PMS';
  document.getElementById('logoCompanyName').textContent=name.length>12?name.substring(0,12)+'…':name;
  // Apply logo to sidebar if exists
  if(settings.company_logo){
    const logo=document.getElementById('sidebarLogo');
    logo.querySelector('.logo-icon').style.display='none';
    if(!logo.querySelector('img')){
      const img=document.createElement('img');
      img.src=settings.company_logo;
      img.style.cssText='width:34px;height:34px;object-fit:contain;border-radius:6px;';
      logo.insertBefore(img, logo.firstChild);
    }
  }
}
async function saveSettings(){
  const btn=document.getElementById('saveSettingsBtn');
  btn.textContent='Saving…'; btn.disabled=true;
  try {
    const keys=['company_name','company_address','company_phone','company_email','currency','vat_rate'];
    const payload={};
    keys.forEach(k=>{ const el=document.getElementById('setting_'+k); if(el) payload[k]=el.value; });
    const res=await fetch('/api/settings',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const data=await res.json();
    if(data.success){
      // Save logo if pending
      if(pendingLogoBase64){
        await fetch('/api/settings/logo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({logoBase64:pendingLogoBase64})});
        pendingLogoBase64=null;
      }
      showToast('Settings saved!','success');
      settings=await fetch('/api/settings').then(r=>r.json());
      applyBranding();
    } else { showToast(data.error||'Failed to save','error'); }
  } catch(e){ showToast('Error: '+e.message,'error'); }
  btn.textContent='💾 Save Settings'; btn.disabled=false;
}
function handleLogoUpload(event){
  const file=event.target.files[0]; if(!file) return;
  if(file.size>800000){ showToast('Logo too large — max 800KB','error'); return; }
  const reader=new FileReader();
  reader.onload=e=>{
    pendingLogoBase64=e.target.result;
    document.getElementById('logoPreviewWrap').innerHTML=`<img class="logo-preview" src="${e.target.result}" alt="Logo">`;
    showToast('Logo ready — click Save Settings to apply','info');
  };
  reader.readAsDataURL(file);
}

