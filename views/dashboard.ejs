              <div>
                <input type="file" id="logoFileInput" accept="image/*" style="display:none" onchange="handleLogoUpload(event)">
                <button onclick="document.getElementById('logoFileInput').click()" style="padding:8px 16px;border:1px solid var(--border);border-radius:8px;font-size:13px;cursor:pointer;background:var(--card)">📁 Choose Logo</button>
                <div style="font-size:12px;color:var(--text-light);margin-top:6px">PNG, JPG — max 500KB recommended</div>
              </div>
            </div>
