<div class="dashboard">
  <h1 class="page-title">Dashboard</h1>

  <div class="stats-grid">
    <div class="stat-card primary">
      <div class="stat-icon">🏢</div>
      <div class="stat-info">
        <h3><%= stats.properties %></h3>
        <p>Properties</p>
      </div>
    </div>
    <div class="stat-card success">
      <div class="stat-icon">🔑</div>
      <div class="stat-info">
        <h3><%= stats.occupied %>/<%= stats.units %></h3>
        <p>Occupied</p>
      </div>
    </div>
    <div class="stat-card warning">
      <div class="stat-icon">🏠</div>
      <div class="stat-info">
        <h3><%= stats.tenants %></h3>
        <p>Tenants</p>
      </div>
    </div>
    <div class="stat-card danger">
      <div class="stat-icon">💵</div>
      <div class="stat-info">
        <h3>$<%= stats.collected.toFixed(2) %></h3>
        <p>Collected</p>
      </div>
    </div>
  </div>

  <div class="quick-actions">
    <h2>Quick Actions</h2>
    <div class="action-grid">
      <a href="/payments" class="action-btn">💵 Record Payment</a>
      <a href="/tenants" class="action-btn">➕ Add Tenant</a>
      <a href="/expenses" class="action-btn">📉 Add Expense</a>
      <a href="/invoices" class="action-btn">📄 Gen Invoice</a>
    </div>
  </div>

  <div class="section-card">
    <h2>Recent Payments</h2>
    <% if (recentPayments.length > 0) { %>
      <div class="list-group">
        <% recentPayments.forEach(p => { %>
          <div class="list-item">
            <div class="item-main">
              <strong><%= p.TenantID %></strong>
              <span class="badge"><%= p.PaymentMethod || 'Cash' %></span>
            </div>
            <div class="item-sub">
              <span><%= p.Period %></span>
              <span class="amount">$<%= parseFloat(p.Amount).toFixed(2) %></span>
            </div>
            <a href="/receipt/<%= p.PaymentID %>" target="_blank" class="btn-small">🧾 Receipt</a>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty">No payments recorded yet.</p>
    <% } %>
  </div>

  <div class="section-card">
    <h2>Financial Overview</h2>
    <div class="finance-grid">
      <div class="finance-item">
        <span>Monthly Rent Potential</span>
        <strong>$<%= stats.monthlyRent.toFixed(2) %></strong>
      </div>
      <div class="finance-item">
        <span>Total Expenses</span>
        <strong class="text-danger">$<%= stats.expenses.toFixed(2) %></strong>
      </div>
      <div class="finance-item highlight">
        <span>Net Balance</span>
        <strong>$<%= stats.balance.toFixed(2) %></strong>
      </div>
    </div>
  </div>
</div>