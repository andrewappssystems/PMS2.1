        </div>
        <div class="data-table">
          <div class="table-header"><h3>All Users</h3></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Username</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
