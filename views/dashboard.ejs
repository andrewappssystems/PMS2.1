function autoFillUnit() {
  const sel = document.getElementById('f_tenant');
  if(!sel) return;
  const unitId = sel.selectedOptions[0]?.dataset?.unit || '';
  const unitInput = document.getElementById('f_unit');
  if(unitInput) unitInput.value = unitId;
  const t = tenants.find(x=>x.ID===sel.value);
  if(t && t['Rent Amount']) {
    const amtInput = document.getElementById('f_amount');
    if(amtInput && !amtInput.value) amtInput.value = t['Rent Amount'];
  }
}

function updateInvoiceEntity() {
  const typeSel = document.getElementById('f_invType');
  const entitySel = document.getElementById('f_entity');
  if(!typeSel || !entitySel) return;
  const type = typeSel.value;
  entitySel.disabled = false;
  if(type==='landlord') {
    const activeLL = landlords.filter(l=>l.Status==='Active' || !l.Status);
    entitySel.innerHTML = '<option value="">Select landlord...</option>' + activeLL.map(l=>`<option value="${l.ID||''}">${l.Name||l.ID||''}</option>`).join('');
  } else if(type==='tenant') {
    const activeTnt = tenants.filter(t=>t.Status==='Active' || !t.Status);
    entitySel.innerHTML = '<option value="">Select tenant...</option>' + activeTnt.map(t=>`<option value="${t.ID||''}">${t.Name||t.ID||''}</option>`).join('');
  } else {
    entitySel.disabled = true;
    entitySel.innerHTML = '<option value="">Select type first...</option>';
  }
}

