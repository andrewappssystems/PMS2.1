<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ManageMate — Dashboard</title>
<link rel="stylesheet" href="/css/design-system.css">
<style>
:root{
  --bg:#FFFFFF;
  --surface:#FAFCFB;
  --surface-strong:#FFFFFF;
  --surface-soft:#F4FBF8;
  --primary:#219377;
  --primary-soft:#D9F3EC;
  --accent:#FFBD59;
  --accent-soft:#FFF4DC;
  --text:#010101;
  --muted:#525252;
  --border:#E5ECE7;
  --shadow:0 22px 50px rgba(1,1,1,0.08);
  --radius-card:20px;
  --radius-input:14px;
  --radius-button:12px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{font-size:16px;}
body{font-family:'Mona Sans','Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;line-height:1.55;}
img{max-width:100%;display:block;}
button,input,select,textarea{font:inherit;}
button{cursor:pointer;}
.app{display:flex;min-height:100vh;background:var(--bg);}
.sidebar{width:210px;position:fixed;inset:0;background:linear-gradient(180deg,#219377 0%,#1f8c7a 100%);color:#fff;overflow-y:auto;padding:18px 14px;box-shadow:0 24px 72px rgba(1,1,1,0.12);}
.sidebar .logo {
  padding: 24px 20px;
  border-bottom: 1px solid rgba(255,255,255,.1);
  display: flex;
  align-items: center;
  gap: 10px;
}
.sidebar .logo .logo-text {
  font-size: 22px;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.5px;
}
.sidebar .logo .logo-dot {
  color: #FFBD59;
}
.sidebar .logo img,
.sidebar .logo .logo-icon,
.sidebar .logo .logo-img {
  display: none !important;
}
.sidebar nav{display:grid;gap:6px;}
.sidebar nav .nav-section{margin-top:16px;margin-bottom:6px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.26em;opacity:.75;}
.sidebar nav a{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:14px;text-decoration:none;color:#fff;font-size:12px;font-weight:700;transition:transform .2s,background .2s;}
.sidebar nav a:hover{background:rgba(255,255,255,0.12);transform:translateX(1px);}
.sidebar nav a.active{background:rgba(255,255,255,0.18);box-shadow:none;}
.nav-icon{width:28px;height:28px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;color:rgba(255,255,255,0.95);}
.nav-icon.green{color:#bbf7d0;}
.nav-icon.yellow{color:#fde68a;}
.sidebar .user-info{display:none;}
.main{flex:1;margin-left:210px;display:flex;flex-direction:column;}
.topbar {
  background: #fff;
  padding: 0 32px;
  height: 64px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #f1f1f1;
  position: sticky;
  top: 0;
  z-index: 50;
  flex-shrink: 0; 
  height: 64px;
  max-height: 64px; 
}
.topbar .topbar-left {
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.topbar .topbar-left .greeting {
  font-size: 13px;
  color: #64748b;
  font-weight: 400;
}
.topbar .topbar-left .username {
  font-size: 16px;
  font-weight: 700;
  color: #010101;
}
.topbar .topbar-left .role-badge {
  font-size: 11px;
  font-weight: 600;
  background: rgba(33,147,119,.1);
  color: #219377;
  padding: 3px 10px;
  border-radius: 20px;
  margin-left: 4px;
}
.topbar .topbar-right {
  display: flex;
  align-items: center;
  gap: 20px;
}
.topbar .topbar-right .datetime {
  text-align: right;
  font-size: 12px;
  color: #64748b;
  line-height: 1.5;
}
.topbar .topbar-right .datetime strong {
  display: block;
  font-size: 13px;
  color: #010101;
  font-weight: 600;
}
.topbar .signout-btn {
  padding: 0 18px;
  height: 38px;
  border-radius: 50px;
  border: 1px solid #e2e8f0;
  background: #fff;
  color: #64748b;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: all 0.2s;
}
.topbar .signout-btn:hover {
  border-color: #219377;
  color: #219377;
}
.topbar .mobile-menu {
  display: none;
  background: none;
  border: none;
  font-size: 22px;
  cursor: pointer;
}
@media(max-width:768px){
  .topbar .mobile-menu { display: block; }
  .topbar .topbar-left .greeting { display: none; }
}
.content{flex:1;overflow-y:auto;padding:32px;background:var(--bg);display:flex;flex-direction:column;}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:16px;}
.stat-card {
  background: #EAF8F4;
  border-radius: 16px;
  padding: 24px;
  border-left: 4px solid #219377;
  box-shadow: none;
}
.stat-card .label {
  font-size: 11px;
  color: #219377;
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: .6px;
  margin-bottom: 10px;
}
.stat-card .value {
  font-size: 28px;
  font-weight: 700;
  color: #010101;
}
.stat-card.warning {
  background: #FFF4DE;
  border-left-color: #FFBD59;
}
.stat-card.warning .label { color: #B87D00; }
.stat-card.warning .value { color: #B87D00; }
.stat-card.danger {
  background: #FFE5E5;
  border-left-color: #ef4444;
}
.stat-card.danger .label { color: #991b1b; }
.stat-card.danger .value { color: #dc2626; }
.stat-card.green-value .value { color: #219377; }
.alert-bar{display:none;align-items:center;gap:12px;padding:16px 18px;border-radius:22px;border:1px solid rgba(33,147,119,0.2);background:rgba(33,147,119,0.08);color:var(--text);margin-bottom:22px;}
.arrears-widget{background:var(--surface);border-radius:var(--radius-card);padding:24px;box-shadow:var(--shadow);margin-bottom:22px;}
.arrears-widget h3{font-size:20px;font-weight:900;margin-bottom:18px;}
.arrears-list{display:grid;gap:16px;}
.arrears-item{display:grid;grid-template-columns:1fr auto;gap:16px;padding:20px;border-radius:18px;background:var(--surface-strong);border:1px solid rgba(1,1,1,0.06);}
.ai-info{font-size:14px;font-weight:800;color:var(--text);}
.ai-sub{font-size:13px;color:var(--muted);}
.ai-amt{font-size:15px;font-weight:900;color:#B91C1C;}
.quick-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.quick-actions button {
  padding: 0 24px;
  height: 44px;
  border-radius: 50px;
  border: none;
  background: #219377;
  color: #fff;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 4px 12px rgba(33, 147, 119, 0.35);
  white-space: nowrap;
  letter-spacing: 0.2px;
}
.quick-actions button:hover {
  background: #1a7660;
  box-shadow: 0 6px 18px rgba(33, 147, 119, 0.45);
  transform: translateY(-1px);
}
.quick-actions button.secondary {
  background: #FFBD59;
  color: #010101;
  box-shadow: 0 4px 12px rgba(255, 189, 89, 0.4);
}
.quick-actions button.secondary:hover {
  background: #f0ad45;
  box-shadow: 0 6px 18px rgba(255, 189, 89, 0.5);
  transform: translateY(-1px);
}
.quick-actions button.danger {
  background: #fee2e2;
  color: #991b1b;
  box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
}
.data-table{background:var(--surface);border-radius:var(--radius-card);overflow:hidden;border:1px solid rgba(1,1,1,0.06);box-shadow:var(--shadow);}
.table-header{padding:18px 20px;display:flex;justify-content:space-between;align-items:center;gap:16px;border-bottom:1px solid rgba(1,1,1,0.06);}
.table-header h3{font-size:17px;font-weight:900;}
.search{padding:12px 14px;border-radius:14px;border:1px solid rgba(1,1,1,0.08);font-size:13px;width:240px;background:var(--surface-strong);color:var(--text);}
table{width:100%;border-collapse:collapse;font-size:14px;}
th{text-align:left;padding:18px 20px;background:var(--surface-strong);font-size:12px;text-transform:uppercase;color:var(--muted);letter-spacing:.16em;}
td{padding:18px 20px;border-bottom:1px solid rgba(1,1,1,0.06);color:var(--text);}
tr:hover td{background:var(--surface-soft);}
.skeleton{background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200% 100%;animation:shimmer 1.4s infinite;border-radius:8px;height:14px;display:inline-block;}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.sk-row td{padding:16px 18px;}
.sk-row td div{height:14px;border-radius:8px;background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200% 100%;animation:shimmer 1.4s infinite;margin:4px 0;}
.badge{display:inline-block;padding:5px 12px;border-radius:999px;font-size:11px;font-weight:800;text-transform:uppercase;}
.badge.success{background:rgba(34,197,94,0.12);color:#166534;}
.badge.danger{background:rgba(239,68,68,0.12);color:#991b1b;}
.badge.warning{background:rgba(255,189,89,0.16);color:#B76E00;}
.badge.info{background:rgba(33,147,255,0.14);color:#1D4ED8;}
.actions{display:flex;gap:8px;flex-wrap:wrap;}
.actions button{padding:10px 14px;border-radius:14px;border:none;font-size:12px;font-weight:700;cursor:pointer;}
.btn-edit{background:rgba(59,130,246,0.12);color:#1D4ED8;}
.btn-delete{background:rgba(239,68,68,0.12);color:#991b1b;}
.btn-view{background:rgba(15,118,110,0.12);color:#115E59;}
.btn-receipt{background:rgba(34,197,94,0.12);color:#166534;}
.btn-pwd{background:rgba(255,189,89,0.16);color:#B76E00;}
.btn-wa{background:rgba(34,197,94,0.12);color:#166534;}
.btn-increase{background:rgba(126,34,206,0.12);color:#6D28D9;}
.empty-state{text-align:center;padding:52px 24px;}
.empty-state .icon{font-size:42px;margin-bottom:12px;}
.empty-state h3{font-size:17px;color:var(--muted);}
.pagination{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-top:1px solid rgba(1,1,1,0.06);font-size:13px;color:var(--muted);}
.pg-btns{display:flex;gap:8px;}
.pg-btns button{padding:8px 12px;border:1px solid rgba(1,1,1,0.08);border-radius:12px;background:var(--surface-strong);font-size:13px;cursor:pointer;}
.pg-btns button:hover:not(:disabled){background:var(--primary);color:#fff;border-color:var(--primary);}
.pg-btns button:disabled{opacity:.4;cursor:not-allowed;}
.pg-btns button.active{background:var(--primary);color:#fff;border-color:var(--primary);}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(1,1,1,0.18);z-index:200;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.active{display:flex;}
.modal{background:var(--surface-strong);border-radius:22px;width:100%;max-width:680px;max-height:92vh;overflow-y:auto;box-shadow:0 28px 80px rgba(1,1,1,0.18);}
.modal.wide{max-width:780px;}
.modal-header{padding:22px 26px;border-bottom:1px solid rgba(1,1,1,0.06);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:var(--surface-strong);z-index:1;}
.modal-header h2{font-size:20px;font-weight:900;}
.modal-header .close{background:none;border:none;font-size:24px;color:var(--muted);cursor:pointer;}
.modal-body{padding:26px;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.form-group{display:flex;flex-direction:column;gap:8px;}
.form-group.full{grid-column:1/-1;}
.form-group label{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.18em;}
.form-group input,.form-group select,.form-group textarea{padding:14px 16px;border:1px solid rgba(1,1,1,0.08);border-radius:var(--radius-input);font-size:14px;background:var(--surface-strong);outline:none;color:var(--text);}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--primary);box-shadow:0 0 0 6px rgba(33,147,119,0.12);}
.form-group textarea{min-height:100px;resize:vertical;}
.modal-footer{padding:18px 26px;border-top:1px solid rgba(1,1,1,0.06);display:flex;justify-content:flex-end;gap:12px;position:sticky;bottom:0;background:var(--surface-strong);}
.modal-footer button{padding:13px 22px;border-radius:var(--radius-button);font-weight:800;font-size:14px;cursor:pointer;border:none;}
.btn-cancel{background:var(--surface);color:var(--text);}
.btn-save{background:var(--primary);color:#fff;}
.unit-preview{background:var(--surface-soft);border:1px solid rgba(1,1,1,0.06);border-radius:var(--radius-input);padding:16px;max-height:144px;overflow-y:auto;margin-top:8px;}
.preview-tag{display:inline-block;background:rgba(33,147,119,0.12);color:var(--primary);padding:6px 12px;border-radius:999px;font-size:12px;margin:2px;}
.settings-row{display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-bottom:1px solid rgba(1,1,1,0.06);gap:18px;}
.settings-row label{font-size:13px;font-weight:800;min-width:160px;color:var(--text);}
.settings-row input{flex:1;padding:14px 16px;border:1px solid rgba(1,1,1,0.08);border-radius:var(--radius-input);font-size:14px;background:var(--surface-strong);outline:none;color:var(--text);}
.settings-row input:focus{border-color:var(--primary);box-shadow:0 0 0 6px rgba(33,147,119,0.12);}
.logo-preview{width:92px;height:92px;object-fit:contain;border-radius:22px;border:1px solid rgba(1,1,1,0.08);}
.logo-placeholder{width:92px;height:92px;border-radius:22px;border:2px dashed rgba(1,1,1,0.12);display:flex;align-items:center;justify-content:center;font-size:22px;color:var(--muted);}
.section{display:none;}
.section.active{display:block;}
.section-title{font-size:30px;font-weight:900;margin-bottom:24px;letter-spacing:-0.04em;}
.report-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;margin-bottom:26px;}
.report-card{background:var(--surface-strong);border-radius:var(--radius-card);padding:26px;box-shadow:var(--shadow);cursor:pointer;border:1px solid rgba(1,1,1,0.06);transition:transform .2s,box-shadow .2s;}
.report-card:hover{transform:translateY(-2px);box-shadow:0 24px 60px rgba(1,1,1,0.12);}
.report-card .icon{width:50px;height:50px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:18px;background:rgba(33,147,119,0.12);color:var(--primary);}
.report-card.yellow .icon{background:rgba(255,189,89,0.18);color:#B76E00;}
.report-card h3{font-size:18px;font-weight:900;margin-bottom:10px;}
.report-card p{font-size:14px;color:var(--muted);line-height:1.7;}
.toast{position:fixed;bottom:24px;right:24px;padding:16px 24px;border-radius:18px;color:var(--text);font-weight:800;font-size:13px;z-index:400;transform:translateY(100px);opacity:0;transition:.3s;max-width:360px;box-shadow:0 24px 72px rgba(1,1,1,0.16);}
.toast.show{transform:translateY(0);opacity:1;}
.toast.success{background:rgba(34,197,94,0.12);color:#064E3B;}
.toast.error{background:rgba(239,68,68,0.12);color:#7F1D1D;}
.toast.info{background:rgba(59,130,246,0.12);color:#1E40AF;}
.prompt-overlay{display:none;position:fixed;inset:0;background:rgba(1,1,1,0.22);z-index:300;align-items:center;justify-content:center;padding:16px;}
.prompt-overlay.active{display:flex;}
.prompt-box{background:var(--surface-strong);border-radius:22px;padding:32px;max-width:440px;width:100%;text-align:center;box-shadow:0 28px 80px rgba(1,1,1,0.16);}
.prompt-box h3{font-size:22px;margin-bottom:14px;font-weight:900;}
.prompt-box p{color:var(--muted);margin-bottom:24px;font-size:15px;line-height:1.7;}
.prompt-buttons{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.prompt-buttons button{padding:12px 22px;border-radius:var(--radius-button);font-weight:800;cursor:pointer;border:none;}
.btn-yes{background:var(--primary);color:#fff;}
.btn-no{background:var(--surface);color:var(--text);}
.btn-yes.danger{background:#EF4444;color:#fff;}
.undo-bar{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--surface-strong);color:var(--text);padding:16px 22px;border-radius:18px;display:flex;align-items:center;gap:18px;font-size:14px;z-index:350;transition:.3s;white-space:nowrap;box-shadow:0 24px 72px rgba(1,1,1,0.16);}
.undo-bar.show{transform:translateX(-50%) translateY(0);}
.undo-bar button{padding:8px 18px;background:var(--primary);color:#fff;border:none;border-radius:14px;font-weight:700;cursor:pointer;font-size:13px;}
@media(max-width:1100px){.sidebar{width:240px;}.main{margin-left:240px;}.content{padding:28px;}.stats-grid{grid-template-columns:repeat(auto-fit,minmax(200px,1fr));}}
@media(max-width:860px){.sidebar{position:fixed;transform:translateX(-100%);} .sidebar.open{transform:translateX(0);}.main{margin-left:0;}.topbar{padding:18px 20px;}.topbar .mobile-menu{display:block;}.content{padding:22px;}.stats-grid{grid-template-columns:1fr;}.report-cards{grid-template-columns:1fr;}.table-header{flex-direction:column;align-items:flex-start;}.search{width:100%!important;}}
</style>
</head>
<body>
<div class="app">
  <aside class="sidebar" id="sidebar">
<div class="logo" id="sidebarLogo">
  <span class="logo-text">Manage<span class="logo-dot">Mate</span></span>
</div>
    <nav>
      <a class="active" onclick="showSection('dashboard',event)"><span class="nav-icon green">📊</span> Dashboard</a>
      <div class="nav-section">Portfolio</div>
      <a onclick="showSection('landlords',event)"><span class="nav-icon green">👤</span> Landlords</a>
      <a onclick="showSection('properties',event)"><span class="nav-icon green">🏘️</span> Properties</a>
      <a onclick="showSection('units',event)"><span class="nav-icon green">🚪</span> Units</a>
      <div class="nav-section">Leasing</div>
      <a onclick="showSection('tenants',event)"><span class="nav-icon green">👥</span> Tenants</a>
      <a onclick="showSection('rent',event)"><span class="nav-icon yellow">💰</span> Rent Collection</a>
      <a onclick="showSection('arrears',event)"><span class="nav-icon yellow">⚠️</span> Arrears</a>
      <div class="nav-section">Finance</div>
      <a onclick="showSection('expenses',event)"><span class="nav-icon yellow">📑</span> Expenses</a>
      <a onclick="showSection('invoices',event)"><span class="nav-icon yellow">📄</span> Invoices</a>
      <a onclick="showSection('receipts',event)"><span class="nav-icon yellow">🧾</span> Receipts</a>
      <div class="nav-section">Analytics</div>
      <a onclick="showSection('reports',event)"><span class="nav-icon green">📈</span> Reports</a>
      <div class="nav-section" id="navAdminLabel">Admin</div>
      <a onclick="showSection('users',event)" id="navUsers"><span class="nav-icon green">🔐</span> Users</a>
      <a onclick="showSection('archive',event)" id="navArchive"><span class="nav-icon yellow">🗃️</span> Archive</a>
      <a onclick="showSection('settings',event)" id="navSettings"><span class="nav-icon green">⚙️</span> Settings</a>
    </nav>
    <div class="user-info">
    </div>
  </aside>
<div class="main">
  <div class="topbar">
    <button class="mobile-menu" onclick="toggleSidebar()">☰</button>
    <div class="topbar-left">
      <span class="greeting">Welcome back,</span>
      <span class="username" id="userName">—</span>
      <span class="role-badge" id="userRole">—</span>
    </div>
    <div class="topbar-right">
      <div class="datetime">
        <strong id="topbarTime">—</strong>
        <span id="dashDate">—</span>
      </div>
      <button class="signout-btn" onclick="logout()">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign Out
      </button>
    </div>
  </div>
  <div class="content">
    <div class="alert-bar" id="rentDueBar"></div>

    <!-- ══ DASHBOARD ══ -->
    <div class="section active" id="sec-dashboard">
        <div class="stats-grid">
  <div class="stat-card"><div class="label">Landlords</div><div class="value" id="statLandlords">—</div></div>
  <div class="stat-card"><div class="label">Properties</div><div class="value" id="statProperties">—</div></div>
  <div class="stat-card"><div class="label">Units</div><div class="value" id="statUnits">—</div></div>
  <div class="stat-card"><div class="label">Active Tenants</div><div class="value" id="statTenants">—</div></div>
  <div class="stat-card"><div class="label">Occupied</div><div class="value" id="statOccupied">—</div></div>
  <div class="stat-card warning"><div class="label">Vacant</div><div class="value" id="statVacant">—</div></div>
  <div class="stat-card green-value"><div class="label">Rent Collected</div><div class="value" id="statRent" style="font-size:18px">—</div></div>
  <div class="stat-card"><div class="label">Total Expenses</div><div class="value" id="statExpenses" style="font-size:18px">—</div></div>
  <div class="stat-card danger"><div class="label">Total Arrears</div><div class="value" id="statArrears" style="font-size:18px">—</div></div>
  <div class="stat-card danger"><div class="label">Tenants in Arrears</div><div class="value" id="statArrearsCount">—</div></div>
</div>
        <div class="arrears-widget" id="criticalWidget" style="display:none">
          <h3>🚨 Critical Arrears <span id="criticalSub" style="font-size:12px;font-weight:400;color:var(--text-light)"></span></h3>
          <div class="arrears-list" id="criticalList"></div>
          <div style="margin-top:12px"><button class="secondary" style="padding:9px 16px;border-radius:14px;border:1px solid rgba(33,147,119,0.16);background:var(--card);color:var(--primary);font-weight:700;font-size:13px;cursor:pointer" onclick="showSection('arrears',event)">View All Arrears →</button></div>
        </div>
        <div class="quick-actions">
  <button onclick="openModal('landlord')">+ Landlord</button>
  <button onclick="openModal('property')">+ Property</button>
  <button onclick="openModal('unit')">+ Unit</button>
  <button onclick="openModal('tenant')">+ Tenant</button>
  <button class="secondary" onclick="openModal('rent')">+ Record Rent</button>
  <button class="secondary" onclick="openModal('expense')">+ Expense</button>
  <button class="secondary" onclick="openModal('invoice')">+ Invoice</button>
  <button class="secondary" onclick="openModal('custom_invoice')">+ Custom Invoice</button>
</div>
</div>
        <div class="report-cards"></div>
</div>

      <!-- ══ LANDLORDS ══ -->
      <div class="section" id="sec-landlords">
        <div class="section-title">Landlords</div>
        <div class="quick-actions"><button onclick="openModal('landlord')">+ Add Landlord</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Landlords</h3><input class="search" placeholder="Search..." oninput="filterTable('tLandlords',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Email</th><th>Commission</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="tLandlords"><tr class="sk-row"><td colspan="7"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcLandlords"></div>
        </div>
      </div>

      <!-- ══ PROPERTIES ══ -->
      <div class="section" id="sec-properties">
        <div class="section-title">Properties</div>
        <div class="quick-actions"><button onclick="openModal('property')">+ Add Property</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Properties</h3><input class="search" placeholder="Search..." oninput="filterTable('tProperties',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Landlord</th><th>Address</th><th>Type</th><th>Units</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="tProperties"><tr class="sk-row"><td colspan="8"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcProperties"></div>
        </div>
      </div>

      <!-- ══ UNITS ══ -->
      <div class="section" id="sec-units">
        <div class="section-title">Units</div>
        <div class="quick-actions">
          <button onclick="openModal('unit')">+ Add Unit</button>
          <button class="secondary" onclick="openModal('bulk_unit')">+ Bulk Add Units</button>
        </div>
        <div class="data-table">
          <div class="table-header"><h3>All Units</h3><input class="search" placeholder="Search..." oninput="filterTable('tUnits',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Property</th><th>Unit No.</th><th>Type</th><th>Rent (UGX)</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="tUnits"><tr class="sk-row"><td colspan="7"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcUnits"></div>
        </div>
      </div>

      <!-- ══ TENANTS ══ -->
      <div class="section" id="sec-tenants">
        <div class="section-title">Tenants</div>
        <div class="quick-actions"><button onclick="openModal('tenant')">+ Add Tenant</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Tenants</h3><input class="search" placeholder="Search..." oninput="filterTable('tTenants',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Unit</th><th>Monthly Rent</th><th>Lease End</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="tTenants"><tr class="sk-row"><td colspan="8"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcTenants"></div>
        </div>
      </div>

      <!-- ══ RENT ══ -->
      <div class="section" id="sec-rent">
        <div class="section-title">Rent Collection</div>
        <div class="quick-actions"><button onclick="openModal('rent')">+ Record Payment</button></div>
        <div class="data-table">
          <div class="table-header"><h3>Payment History</h3><input class="search" placeholder="Search..." oninput="filterTable('tRent',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Tenant</th><th>Unit</th><th>Amount (UGX)</th><th>Period</th><th>Type</th><th>Method</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody id="tRent"><tr class="sk-row"><td colspan="9"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcRent"></div>
          <div class="pagination" id="pgRent" style="display:none"></div>
        </div>
      </div>

      <!-- ══ ARREARS ══ -->
      <div class="section" id="sec-arrears">
        <div class="section-title">Arrears</div>
        <div class="data-table">
          <div class="table-header"><h3>Outstanding Rent</h3></div>
          <table><thead><tr><th>Tenant</th><th>Unit</th><th>Property</th><th>Monthly Rent</th><th>Months Due</th><th>Balance (UGX)</th><th>Level</th><th>Actions</th></tr></thead>
          <tbody id="tArrears"><tr class="sk-row"><td colspan="8"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcArrears"></div>
        </div>
      </div>

      <!-- ══ EXPENSES ══ -->
      <div class="section" id="sec-expenses">
        <div class="section-title">Expenses</div>
        <div class="quick-actions"><button onclick="openModal('expense')">+ Add Expense</button></div>
        <div class="data-table">
          <div class="table-header"><h3>All Expenses</h3><input class="search" placeholder="Search..." oninput="filterTable('tExpenses',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Property</th><th>Category</th><th>Description</th><th>Amount (UGX)</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody id="tExpenses"><tr class="sk-row"><td colspan="7"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcExpenses"></div>
          <div class="pagination" id="pgExpenses" style="display:none"></div>
        </div>
      </div>

      <!-- ══ INVOICES ══ -->
      <div class="section" id="sec-invoices">
        <div class="section-title">Invoices</div>
        <div class="quick-actions">
          <button onclick="openModal('invoice')">+ Create Invoice</button>
          <button class="secondary" onclick="openModal('bulk_invoice')">+ Bulk Management Fees</button>
        </div>
        <div class="data-table">
          <div class="table-header"><h3>All Invoices</h3><input class="search" placeholder="Search..." oninput="filterTable('tInvoices',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Type</th><th>Entity</th><th>Description</th><th>Amount (UGX)</th><th>Period</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="tInvoices"><tr class="sk-row"><td colspan="8"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcInvoices"></div>
          <div class="pagination" id="pgInvoices" style="display:none"></div>
        </div>
      </div>

      <!-- ══ RECEIPTS ══ -->
      <div class="section" id="sec-receipts">
        <div class="section-title">Receipts</div>
        <div class="data-table">
          <div class="table-header"><h3>All Receipts</h3><input class="search" placeholder="Search..." oninput="filterTable('tReceipts',this.value)"></div>
          <table><thead><tr><th>ID</th><th>Tenant</th><th>Unit</th><th>Amount (UGX)</th><th>Period</th><th>Type</th><th>Method</th><th>Date</th><th>Actions</th></tr></thead>
          <tbody id="tReceipts"><tr class="sk-row"><td colspan="9"><div style="width:60%"></div></td></tr></tbody></table>
          <div class="mobile-cards" id="mcReceipts"></div>
          <div class="pagination" id="pgReceipts" style="display:none"></div>
        </div>
      </div>

      <!-- ══ REPORTS ══ -->
      <div class="section" id="sec-reports">
        <div class="section-title">Reports & Analytics</div>
        <div class="report-cards">
          <div class="report-card" onclick="openReportModal('portfolio')">
            <div class="icon">📊</div>
            <h3>Portfolio Report</h3>
            <p>Full summary — all properties, rent collected, expenses, occupancy & arrears across the portfolio.</p>
          </div>
          <div class="report-card" onclick="openReportModal('landlord')">
            <div class="icon">👤</div>
            <h3>Landlord Report</h3>
            <p>Per-landlord statement — rent collected, management fee, expenses, arrears & net disbursement.</p>
          </div>
          <div class="report-card" onclick="openReportModal('tenant')">
            <div class="icon">👥</div>
            <h3>Tenant Statement</h3>
            <p>Individual tenant payment history, outstanding balance & lease details for any date range.</p>
          </div>
        </div>
      </div>

      <!-- ══ USERS ══ -->
      <div class="section" id="sec-users">
        <div class="section-title">Users</div>
        <div class="quick-actions" id="usersActionsBar" style="display:none">
          <button onclick="openModal('user')">+ Add User</button>
        </div>
        <div class="data-table">
          <div class="table-header"><h3>All Users</h3></div>
          <table><thead><tr><th>ID</th><th>Name</th><th>Username</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="tUsers"><tr class="sk-row"><td colspan="7"><div style="width:60%"></div></td></tr></tbody></table>
        </div>
      </div>

      <!-- ══ ARCHIVE ══ -->
      <div class="section" id="sec-archive">
        <div class="section-title">Deleted Records Archive</div>
        <div class="data-table">
          <div class="table-header">
            <h3>Archive</h3>
            <div style="display:flex;gap:8px;flex-wrap:wrap">
              <select id="archiveTypeFilter" onchange="loadArchive()" style="padding:10px 14px;border:1px solid var(--border);border-radius:14px;font-size:13px">
                <option value="">All types</option>
                <option value="tenant">Tenants</option>
                <option value="landlord">Landlords</option>
              </select>
              <input id="archiveSearch" class="search" placeholder="Search by name..." oninput="loadArchive()" style="width:180px">
            </div>
          </div>
          <table><thead><tr><th>Deleted At</th><th>Type</th><th>ID</th><th>Name / Label</th><th>Deleted By</th></tr></thead>
          <tbody id="tArchive"><tr><td colspan="5" style="text-align:center;padding:30px;color:var(--text-light)">Use the filters above to search deleted records.</td></tr></tbody></table>
        </div>
      </div>

      <!-- ══ SETTINGS ══ -->
      <div class="section" id="sec-settings">
        <div class="section-title">Settings</div>
        <div class="data-table" style="max-width:680px">
          <div class="table-header">
            <h3>System Settings</h3>
            <button id="saveSettingsBtn" style="display:none;padding:10px 18px;background:var(--primary);color:#fff;border:none;border-radius:14px;font-weight:700;cursor:pointer;font-size:13px" onclick="saveSettings()">💾 Save Settings</button>
          </div>
          <div class="settings-row" id="logoRow" style="display:none">
            <label>Company Logo</label>
            <div style="display:flex;align-items:center;gap:14px">
              <div id="logoPreviewWrap"><div class="logo-placeholder">🏢</div></div>
              <div>
                <input type="file" id="logoFileInput" accept="image/*" style="display:none" onchange="handleLogoUpload(event)">
                <button onclick="document.getElementById('logoFileInput').click()" style="padding:9px 16px;border:1px solid var(--border);border-radius:14px;font-size:12px;cursor:pointer;background:var(--card)">📁 Choose Logo</button>
                <div style="font-size:11px;color:var(--text-light);margin-top:4px">PNG / JPG — max 800KB</div>
              </div>
            </div>
          </div>
          <div id="settingsForm"><div style="padding:28px;text-align:center;color:var(--text-light)">Loading settings…</div></div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
  <div class="modal" id="modalBox">
    <div class="modal-header"><h2 id="modalTitle">—</h2><button class="close" onclick="closeModal()">×</button></div>
    <div class="modal-body" id="modalBody"></div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn-save" id="modalSave" onclick="saveForm()">Save</button>
    </div>
  </div>
</div>

<!-- Prompt / Confirm -->
<div class="prompt-overlay" id="promptOverlay" onclick="if(event.target===this)closePrompt()">
  <div class="prompt-box">
    <h3 id="promptTitle">Confirm</h3>
    <p id="promptMessage" style="word-break:break-word"></p>
    <div class="prompt-buttons">
      <button class="btn-yes" id="promptYes">Yes</button>
      <button class="btn-no" onclick="closePrompt()">No</button>
    </div>
  </div>
</div>

<!-- Undo bar -->
<div class="undo-bar" id="undoBar">
  <span id="undoMsg">Deleted</span>
  <button onclick="triggerUndo()">↩ Undo</button>
</div>

<div class="toast" id="toast"> 

</div>

<script>
const USER = JSON.parse('<%- JSON.stringify(user || {}).replace(/</g, "\\u003c") %>');
</script>
<script src="/js/dashboard.js"></script>
</body>
</html>