// ── API fetch helpers ─────────────────────────────────────────────────────────
async function apiFetch(url){ const r=await fetch(url); return r.json(); }

// ── Load all base data (non-paginated) ────────────────────────────────────────
async function loadAllData(){
  try {
    const stats = await apiFetch('/api/stats');
    document.getElementById('statLandlords').textContent  = stats.landlords||0;
    document.getElementById('statProperties').textContent = stats.properties||0;
    document.getElementById('statUnits').textContent      = stats.units||0;
    document.getElementById('statTenants').textContent    = stats.tenants||0;
    document.getElementById('statOccupied').textContent   = stats.occupied||0;
    document.getElementById('statVacant').textContent     = stats.vacant||0;
    document.getElementById('statRent').textContent       = Number(stats.totalRent||0).toLocaleString();
    document.getElementById('statExpenses').textContent   = Number(stats.totalExpenses||0).toLocaleString();
  } catch(e){ console.error('Stats error',e); }

  try { landlords  = await apiFetch('/api/landlords');  renderLandlords(); }  catch(e){ landlords=[];  renderLandlords(); }
  try { properties = await apiFetch('/api/properties'); renderProperties(); } catch(e){ properties=[]; renderProperties(); }
  try { units      = await apiFetch('/api/units');      renderUnits(); }      catch(e){ units=[];      renderUnits(); }
  try { tenants    = await apiFetch('/api/tenants');    renderTenants(); }    catch(e){ tenants=[];    renderTenants(); }
  try { settings   = await apiFetch('/api/settings'); renderSettings(); }    catch(e){ settings={}; }

  // Load paginated tables
  await loadPage('rent',1);
  await loadPage('expenses',1);
  await loadPage('invoices',1);
  await loadPage('receipts',1);

  // Load users if admin
  if(USER.role==='Admin'){
    try { const users=await apiFetch('/api/users'); renderUsers(users); } catch(e){ renderUsers([]); }
  }
}

// ── Paginated loader ──────────────────────────────────────────────────────────
async function loadPage(type, page){
  const urlMap = { rent:'/api/rent', expenses:'/api/expenses', invoices:'/api/invoices', receipts:'/api/receipts' };
  try {
    const res = await apiFetch(`${urlMap[type]}?page=${page}&limit=50`);
    // Handle both paginated {data,total,page,pages} and plain array responses
    const rows  = Array.isArray(res) ? res : (res.data || []);
    const pages = Array.isArray(res) ? 1   : (res.pages || 1);
    pgState[type] = { page: Array.isArray(res) ? 1 : (res.page||1), pages };
    if(type==='rent')     { rentData=rows; renderRent(); renderPagination('rent','rentPagination'); }
    if(type==='expenses') { renderExpensesData(rows); renderPagination('expenses','expensesPagination'); }
    if(type==='invoices') { renderInvoicesData(rows); renderPagination('invoices','invoicesPagination'); }
    if(type==='receipts') { renderReceiptsData(rows); renderPagination('receipts','receiptsPagination'); }
  } catch(e){ console.error(`loadPage ${type}:`, e); }
}

// ── Pagination UI ─────────────────────────────────────────────────────────────
function renderPagination(type, containerId){
  const { page, pages } = pgState[type];
  const el = document.getElementById(containerId);
  if(!el) return;
  if(pages <= 1){ el.style.display='none'; return; }
  el.style.display='flex';
  let btns='';
  const start = Math.max(1, page-2), end = Math.min(pages, page+2);
  if(start>1) btns+=`<button onclick="loadPage('${type}',1)">1</button>`;
  if(start>2) btns+=`<span style="padding:6px 4px">…</span>`;
  for(let i=start;i<=end;i++) btns+=`<button class="${i===page?'active':''}" onclick="loadPage('${type}',${i})">${i}</button>`;
  if(end<pages-1) btns+=`<span style="padding:6px 4px">…</span>`;
  if(end<pages) btns+=`<button onclick="loadPage('${type}',${pages})">${pages}</button>`;
  el.innerHTML=`
    <span>Page ${page} of ${pages}</span>
    <div class="pg-btns">
      <button onclick="loadPage('${type}',${page-1})" ${page<=1?'disabled':''}>← Prev</button>
      ${btns}
      <button onclick="loadPage('${type}',${page+1})" ${page>=pages?'disabled':''}>Next →</button>
    </div>`;
}

